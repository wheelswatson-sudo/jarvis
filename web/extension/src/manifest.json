{
  "manifest_version": 3,
  "name": "Relationship Intelligence",
  "version": "0.1.0",
  "description": "Surface RI context on LinkedIn and Facebook profiles, log social signals back to your contacts.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "https://*.linkedin.com/*",
    "https://*.facebook.com/*",
    "https://relationship-intelligence-blue.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Relationship Intelligence"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*", "https://linkedin.com/in/*"],
      "js": ["content/linkedin.js"],
      "css": ["content/sidebar.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*"
      ],
      "js": ["content/facebook.js"],
      "css": ["content/sidebar.css"],
      "run_at": "document_idle"
    }
  ]
}
