# Copy to .env.local and fill in real values. Do NOT commit .env.local —
# only this template is checked in.
#
# Vercel: manage via `vercel env add <NAME> <env> --value "..." --yes`
# Local cron / iMessage bridge: separate file at ~/.jarvis/config/.env

# ─── Required (always) ──────────────────────────────────────────────────────
# Supabase project — without these the server cannot boot.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ─── Required in production (warn in dev) ───────────────────────────────────
# Shared secret for cron + iMessage bridge auth.
# Bridge sends `Authorization: Bearer <CRON_SECRET>` to /api/cron/* and
# /api/imessage/sync. Must match the value in ~/.jarvis/config/.env.
# Generate: openssl rand -hex 16
CRON_SECRET=replace-with-openssl-rand-hex-16

# Shared secret for the SMS Gateway for Android inbound webhook.
# Gateway sends `Authorization: Bearer <secret>` to /api/sms/webhook.
# Configure the same value in the Android app's webhook settings.
# Generate: openssl rand -hex 32
SMS_GATEWAY_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# ─── Feature-gated (only required when feature is in use) ───────────────────
# Groq — LLM fallback for chat + intelligence extraction.
GROQ_API_KEY=gsk_your-groq-key

# Google OAuth — required to refresh Gmail/Calendar tokens.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sentry — error tracking. Optional but recommended in production.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DASHBOARD_URL=

# Chrome extension — comma-separated chrome-extension://<id> origins
# allowed to call the API. Leave blank to block all extension origins.
EXTENSION_ALLOWED_ORIGINS=

# Public app URL — used to render absolute links in emails / shareables.
# Falls back to the request host when unset.
NEXT_PUBLIC_APP_URL=

# ─── Auto-injected by Vercel (do not set manually) ──────────────────────────
# VERCEL_ENV, VERCEL_URL, VERCEL_GIT_COMMIT_SHA, NEXT_PUBLIC_VERCEL_ENV,
# NEXT_RUNTIME, NODE_ENV
