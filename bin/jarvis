#!/usr/bin/env bash
# JARVIS — Voice-enabled AI assistant powered by Claude + ElevenLabs
# Usage:
#   jarvis "text to speak"            Speak text aloud
#   jarvis on                         Turn voice on (persistent)
#   jarvis off                        Turn voice off (persistent)
#   jarvis auto                       Auto mode — speaks only important responses
#   jarvis status                     Show current voice state
#   jarvis --settings                 Show current personality settings
#   jarvis --set humor 60             Adjust a setting
#   jarvis --voices                   List available voices
#   jarvis --voice <voice_id>         Change voice
#   jarvis --test                     Test voice with a sample line
#   jarvis --help                     Show help

set -euo pipefail

ASSISTANT_DIR="${ASSISTANT_DIR:-$HOME/.jarvis}"
CONFIG_FILE="$ASSISTANT_DIR/config/settings.json"
ENV_FILE="$ASSISTANT_DIR/config/.env"
STATE_FILE="$ASSISTANT_DIR/state.json"
CACHE_DIR="$ASSISTANT_DIR/cache"
TTS_LOG="$ASSISTANT_DIR/logs/tts.log"

tts_log() {
    mkdir -p "$(dirname "$TTS_LOG")" 2>/dev/null || true
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" >> "$TTS_LOG" 2>/dev/null || true
}

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── State management (voice toggle) ──────────────────────────────────
init_state() {
    if [[ ! -f "$STATE_FILE" ]]; then
        mkdir -p "$(dirname "$STATE_FILE")"
        echo '{"voice": "on"}' > "$STATE_FILE"
    fi
}

get_voice_state() {
    init_state
    python3 -c "import json; print(json.load(open('$STATE_FILE')).get('voice', 'on'))"
}

set_voice_state() {
    init_state
    python3 -c "
import json
with open('$STATE_FILE', 'r') as f:
    state = json.load(f)
state['voice'] = '$1'
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"
}

# ─── Load config ───────────────────────────────────────────────────────
load_env() {
    # Keychain takes precedence; .env stays as fallback.
    [[ -f "$ENV_FILE" ]] && source "$ENV_FILE"
    [[ -x "$ASSISTANT_DIR/bin/jarvis-secrets" ]] && eval "$("$ASSISTANT_DIR/bin/jarvis-secrets" --export 2>/dev/null)"
    if [[ -z "${ELEVENLABS_API_KEY:-}${ANTHROPIC_API_KEY:-}${OPENAI_API_KEY:-}" ]]; then
        echo -e "${RED}JARVIS is not configured.${NC} Run: jarvis-setup"
        exit 1
    fi
}

load_settings() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        mkdir -p "$(dirname "$CONFIG_FILE")"
        cat > "$CONFIG_FILE" << 'DEFAULTS'
{
    "voice_id": "JBFqnCBsd6RMkjVDRZzb",
    "voice_name": "George",
    "model_id": "eleven_turbo_v2_5",
    "stability": 0.5,
    "similarity_boost": 0.85,
    "style": 0.2,
    "humor": 75,
    "formality": 80,
    "proactivity": 70,
    "honesty": 90
}
DEFAULTS
    fi
}

get_setting() {
    python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['$1'])"
}

set_setting() {
    python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    cfg = json.load(f)
try:
    cfg['$1'] = int('$2')
except ValueError:
    try:
        cfg['$1'] = float('$2')
    except ValueError:
        cfg['$1'] = '$2'
with open('$CONFIG_FILE', 'w') as f:
    json.dump(cfg, f, indent=4)
print('Updated $1 to $2')
"
}

# Text processing for speech (acronym expansion, markdown stripping) is handled
# inside the consolidated TTS Python helper below — no separate subprocesses.

# ─── Speak function ────────────────────────────────────────────────────
# Two-phase design: a single Python invocation does text processing (markdown
# strip + acronym expansion + length cap) and cache lookup, printing either
# `HIT <path>` for a populated cache file or `MISS <path>\n<payload-json>`
# for a fresh fetch. Bash then either plays the cache (afplay, instant) or
# streams from ElevenLabs's /stream endpoint piped through `tee → mpv stdin`,
# starting playback on the first audio frame.
speak() {
    local text="$1"
    local force="${2:-false}"

    # Voice on/off check stays in bash so the off path has zero subprocess overhead.
    if [[ "$force" != "true" ]]; then
        local state
        state=$(get_voice_state)
        if [[ "$state" == "off" ]]; then
            return 0
        fi
    fi

    [[ -z "$text" ]] && return 0
    mkdir -p "$CACHE_DIR"

    local plan
    plan=$(
        CACHE_DIR="$CACHE_DIR" \
        CONFIG_FILE="$CONFIG_FILE" \
        ASSISTANT_DIR="$ASSISTANT_DIR" \
        python3 - "$text" <<'PYEOF'
import hashlib, json, os, re, sys

ACRONYMS = {
    'API': 'A P I', 'APIs': 'A P Is', 'CLI': 'C L I',
    'URL': 'U R L', 'URLs': 'U R Ls', 'JSON': 'Jason',
    'HTML': 'H T M L', 'CSS': 'C S S', 'SQL': 'sequel',
    'HTTP': 'H T T P', 'HTTPS': 'H T T P S',
    'SSH': 'S S H', 'DNS': 'D N S', 'AWS': 'A W S',
    'GCP': 'G C P', 'MCP': 'M C P', 'SDK': 'S D K',
    'IDE': 'I D E', 'JWT': 'J W T', 'OAuth': 'oh-auth',
    'CRUD': 'crud', 'REST': 'rest', 'UI': 'U I',
    'UX': 'U X', 'AI': 'A I', 'ML': 'M L',
    'GPU': 'G P U', 'CPU': 'C P U', 'RAM': 'ram',
    'SSD': 'S S D', 'NPM': 'N P M', 'PR': 'P R',
    'PRs': 'P Rs', 'CI': 'C I', 'CD': 'C D',
    'TTS': 'T T S', 'STT': 'S T T', 'LLM': 'L L M',
    'GPT': 'G P T', 'TLS': 'T L S', 'TCP': 'T C P',
    'IP': 'I P', 'DB': 'D B',
    'CRM': 'C R M', 'ETA': 'E T A', 'FAQ': 'F A Q',
    'ASAP': 'A S A P', 'CEO': 'C E O', 'CTO': 'C T O',
    'CFO': 'C F O', 'COO': 'C O O', 'VP': 'V P',
}

def strip_markdown(t):
    t = re.sub(r'```[\s\S]*?```', '', t)
    t = re.sub(r'`[^`]+`', '', t)
    t = re.sub(r'^#{1,6}\s+', '', t, flags=re.MULTILINE)
    t = re.sub(r'\*{1,3}([^*]+)\*{1,3}', r'\1', t)
    t = re.sub(r'_{1,3}([^_]+)_{1,3}', r'\1', t)
    t = re.sub(r'\[([^\]]+)\]\([^)]+\)', r'\1', t)
    t = re.sub(r'!\[([^\]]*)\]\([^)]+\)', '', t)
    t = re.sub(r'\|.*\|', '', t)
    t = re.sub(r'^[-:| ]+$', '', t, flags=re.MULTILINE)
    t = re.sub(r'^\s*[-*+]\s+', '', t, flags=re.MULTILINE)
    t = re.sub(r'^\s*\d+\.\s+', '', t, flags=re.MULTILINE)
    t = re.sub(r'^>\s+', '', t, flags=re.MULTILINE)
    t = re.sub(r'^---+$', '', t, flags=re.MULTILINE)
    return re.sub(r'\n{3,}', '\n\n', t).strip()

def clean_for_speech(t, extra_acronyms):
    acronyms = dict(ACRONYMS)
    acronyms.update(extra_acronyms or {})
    for acr, spoken in acronyms.items():
        t = re.sub(r'\b' + re.escape(acr) + r'\b', spoken, t)
    t = re.sub(r'[~/][a-zA-Z0-9_./-]+', '', t)
    t = re.sub(r'https?://\S+', '', t)
    # Stash <break .../> SSML tags so the bracket-stripper below leaves
    # them intact — ElevenLabs Turbo v2.5 honours them as natural pauses.
    breaks = []
    def _stash(m):
        breaks.append(m.group(0))
        return f'\x00B{len(breaks)-1}\x00'
    t = re.sub(r'<break\b[^>]*/>', _stash, t)
    t = re.sub(r'[(){}\[\]<>]', '', t)
    for i, b in enumerate(breaks):
        t = t.replace(f'\x00B{i}\x00', b)
    t = re.sub(r'`+', '', t)
    t = re.sub(r'  +', ' ', t)
    return re.sub(r'\n{3,}', '\n\n', t).strip()

text = sys.argv[1]
cache_dir = os.environ['CACHE_DIR']

with open(os.environ['CONFIG_FILE']) as f:
    cfg = json.load(f)

text = clean_for_speech(strip_markdown(text), cfg.get('extra_acronyms') or {})
if len(text) > 5000:
    text = text[:4990] + '... I shall spare you the remainder, sir.'
if not text:
    sys.exit(0)

voice_id = cfg.get('voice_id', 'JBFqnCBsd6RMkjVDRZzb')
model_id = cfg.get('model_id', 'eleven_turbo_v2_5')
stability = cfg.get('stability', 0.5)
similarity = cfg.get('similarity_boost', 0.85)
style = cfg.get('style', 0.2)

cache_key = hashlib.md5(f'{voice_id}:{model_id}:{text}'.encode()).hexdigest()
audio_file = os.path.join(cache_dir, f'{cache_key}.mp3')

if os.path.isfile(audio_file) and os.path.getsize(audio_file) > 0:
    print(f'HIT\t{audio_file}')
    sys.exit(0)

payload = json.dumps({
    'text': text,
    'model_id': model_id,
    'voice_settings': {
        'stability': stability,
        'similarity_boost': similarity,
        'style': style,
    },
})
print(f'MISS\t{audio_file}\t{voice_id}')
print(payload)
PYEOF
    )
    local rc=$?
    [[ $rc -ne 0 || -z "$plan" ]] && return 0  # empty/cleaned-to-zero-length text

    local status audio_file voice_id payload
    status=$(echo "$plan" | head -1 | cut -f1)
    audio_file=$(echo "$plan" | head -1 | cut -f2)
    voice_id=$(echo "$plan" | head -1 | cut -f3)
    payload=$(echo "$plan" | tail -n +2)

    # ── Cache hit: play instantly via afplay (or mpv fallback) ──
    if [[ "$status" == "HIT" ]]; then
        afplay "$audio_file" 2>/dev/null || mpv --no-video --really-quiet "$audio_file" 2>/dev/null || {
            echo -e "${RED}No audio player found.${NC}"
            return 1
        }
        return 0
    fi

    # ── Cache miss: stream curl → mpv stdin for sub-second first-audio ──
    if [[ -z "${ELEVENLABS_API_KEY:-}" ]]; then
        tts_log "ELEVENLABS_API_KEY not set — falling back to say"
        echo -e "${RED}ELEVENLABS_API_KEY not set.${NC}" >&2
        say "$text" 2>/dev/null || true
        return 1
    fi

    if ! command -v mpv >/dev/null 2>&1; then
        tts_log "mpv not installed — streaming unavailable, falling back to say"
        echo -e "${YELLOW}Install mpv for streaming TTS. Falling back to system voice...${NC}" >&2
        say "$text" 2>/dev/null || true
        return 1
    fi

    echo -e "${CYAN}JARVIS${NC} ${DIM}is speaking...${NC}"

    local tmp_file curl_rc=0
    tmp_file="${audio_file}.partial"
    set +e
    set +o pipefail
    curl -sN --fail \
            "https://api.elevenlabs.io/v1/text-to-speech/${voice_id}/stream?optimize_streaming_latency=2&output_format=mp3_44100_128" \
            -H "xi-api-key: ${ELEVENLABS_API_KEY}" \
            -H "Content-Type: application/json" \
            -d "$payload" \
        | tee "$tmp_file" \
        | mpv --no-video --cache=no --really-quiet --no-terminal - 2>/dev/null
    curl_rc="${PIPESTATUS[0]}"
    set -e
    set -o pipefail

    if [[ "$curl_rc" -ne 0 ]]; then
        rm -f "$tmp_file"
        tts_log "ElevenLabs streaming failed (curl exit $curl_rc) — falling back to macOS say"
        echo -e "${YELLOW}Voice synthesis failed — falling back to system voice.${NC}" >&2
        say "$text" 2>/dev/null || true
        return 1
    fi

    if [[ -s "$tmp_file" ]]; then
        mv -f "$tmp_file" "$audio_file"
    else
        rm -f "$tmp_file"
    fi

    # Trim cache if it's getting big (best-effort, fire-and-forget).
    local cache_size
    cache_size=$(du -sm "$CACHE_DIR" 2>/dev/null | cut -f1)
    if [[ "${cache_size:-0}" -gt 50 ]]; then
        find "$CACHE_DIR" -name '*.mp3' -type f -exec stat -f '%m %N' {} \; 2>/dev/null \
            | sort -rn | tail -n +20 | cut -d' ' -f2- | xargs -I {} rm -f {} 2>/dev/null
    fi
    return 0
}
# ─── Streaming speak (sentence by sentence) ───────────────────────────
# Split input into ~120-char sentence chunks (single Python call), then speak
# each chunk. Each speak() invocation hits cache or fetches independently — for
# large responses this gives the user audio while later chunks are still
# downloading. Use jarvis --stream "long text" for this mode.
speak_streaming() {
    local text="$1"
    local force="${2:-false}"

    if [[ "$force" != "true" ]]; then
        local state
        state=$(get_voice_state)
        if [[ "$state" == "off" ]]; then
            return 0
        fi
    fi

    python3 -c '
import sys, re
text = sys.stdin.read().strip()
# Strip markdown noise so chunk splitting works on prose
text = re.sub(r"```[\s\S]*?```", "", text)
text = re.sub(r"`[^`]+`", "", text)
sentences = re.split(r"(?<=[.!?])\s+", text)
chunks, current = [], ""
for s in sentences:
    if len(current) + len(s) < 120:
        current = (current + " " + s).strip()
    else:
        if current:
            chunks.append(current)
        current = s
if current:
    chunks.append(current)
for chunk in chunks:
    print(chunk)
' <<< "$text" | while IFS= read -r sentence; do
        if [[ -n "$sentence" ]]; then
            speak "$sentence" "$force"
        fi
    done
}

# ─── Commands ──────────────────────────────────────────────────────────
show_help() {
    cat << 'EOF'

    ╔══════════════════════════════════════════════════════╗
    ║              J.A.R.V.I.S. Voice System              ║
    ║       Just A Rather Very Intelligent System          ║
    ╚══════════════════════════════════════════════════════╝

    Voice Control:
      jarvis on                      Turn voice ON
      jarvis off                     Turn voice OFF
      jarvis auto                    Auto mode (smart filtering)
      jarvis status                  Show voice state

    Wake Word ("Hey Jarvis"):
      jarvis wake start              Start always-on listener (background)
      jarvis wake stop               Stop the listener
      jarvis wake status             Check if listener is running
      jarvis wake logs               Tail listener logs

    Commands:
      jarvis greet                   Context-aware greeting + briefing
      jarvis boot                    Run boot-up sequence
      jarvis "text"                  Speak text aloud
      jarvis --stream "text"         Speak with streaming (sentence-by-sentence)
      echo "text" | jarvis           Pipe text to speak

    Configuration:
      jarvis --settings              Show personality settings
      jarvis --set <key> <value>     Adjust a setting
      jarvis --voices                List available ElevenLabs voices
      jarvis --voice <voice_id>      Switch voice
      jarvis --test                  Test voice

    Personality Settings:
      humor       (0-100)  Wit intensity. Default: 75
      formality   (0-100)  Protocol level. Default: 80
      proactivity (0-100)  Anticipation level. Default: 70
      honesty     (0-100)  Directness. Default: 90

    Setup:
      jarvis-setup                   First-time configuration

EOF
}

show_status() {
    local state
    state=$(get_voice_state)
    local icon color label
    case "$state" in
        on)   icon="●" ; color="$GREEN" ; label="ON — All responses spoken" ;;
        off)  icon="○" ; color="$RED"   ; label="OFF — Silent mode" ;;
        auto) icon="◐" ; color="$YELLOW"; label="AUTO — Smart filtering" ;;
    esac
    echo ""
    echo -e "    ${CYAN}JARVIS Voice:${NC} ${color}${icon} ${label}${NC}"
    echo ""
    echo -e "    ${DIM}Toggle:  jarvis on | jarvis off | jarvis auto${NC}"
    echo ""
}

show_settings() {
    echo ""
    echo -e "    ${CYAN}╔══════════════════════════════════════╗${NC}"
    echo -e "    ${CYAN}║${NC}       J.A.R.V.I.S. Settings         ${CYAN}║${NC}"
    echo -e "    ${CYAN}╚══════════════════════════════════════╝${NC}"
    echo ""

    local state
    state=$(get_voice_state)
    local state_icon state_color
    case "$state" in
        on)   state_icon="●" ; state_color="$GREEN" ;;
        off)  state_icon="○" ; state_color="$RED" ;;
        auto) state_icon="◐" ; state_color="$YELLOW" ;;
    esac
    echo -e "    Voice State      ${state_color}${state_icon} ${state}${NC}"
    echo ""

    python3 -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
labels = {
    'voice_name': 'Voice',
    'voice_id': 'Voice ID',
    'model_id': 'Model',
    'stability': 'Stability',
    'similarity_boost': 'Similarity',
    'style': 'Style',
    'humor': 'Humor',
    'formality': 'Formality',
    'proactivity': 'Proactivity',
    'honesty': 'Honesty'
}
for key, label in labels.items():
    val = cfg.get(key, 'N/A')
    bar = ''
    if isinstance(val, int) and 0 <= val <= 100:
        filled = val // 5
        bar = f' [{\"█\" * filled}{\"░\" * (20 - filled)}]'
    print(f'    {label:<16} {val}{bar}')
"
    echo ""
}

list_voices() {
    echo -e "\n    ${CYAN}Available Voices${NC}\n"
    curl -s "https://api.elevenlabs.io/v1/voices" \
        -H "xi-api-key: ${ELEVENLABS_API_KEY}" \
        | python3 -c "
import json, sys
data = json.load(sys.stdin)
for v in data.get('voices', []):
    labels = v.get('labels', {})
    accent = labels.get('accent', 'unknown')
    gender = labels.get('gender', '?')
    desc = labels.get('descriptive', '')
    name = v['name']
    vid = v['voice_id']
    print(f'    {name:<40} {gender:<8} {accent:<15} {vid}')
"
    echo ""
}

test_voice() {
    speak "Systems operational, sir. Voice synthesis is functioning within normal parameters. I trust the quality meets your expectations. If not, I have several alternatives prepared." "true"
}

# ─── Context-aware greeting ───────────────────────────────────────────
greet() {
    local hour greeting time_context day_name
    hour=$(date +%H)
    day_name=$(date +%A)

    if (( hour < 6 )); then
        greeting="Burning the midnight oil, sir?"
        time_context="late_night"
    elif (( hour < 12 )); then
        greeting="Good morning, sir."
        time_context="morning"
    elif (( hour < 17 )); then
        greeting="Good afternoon, sir."
        time_context="afternoon"
    elif (( hour < 21 )); then
        greeting="Good evening, sir."
        time_context="evening"
    else
        greeting="Working late, sir. I trust it is for good reason."
        time_context="night"
    fi

    # Build contextual briefing
    local briefing="$greeting"

    # Day awareness
    case "$day_name" in
        Saturday|Sunday)
            briefing="$briefing It is ${day_name}. I would suggest rest, but I suspect you have other plans."
            ;;
        Monday)
            briefing="$briefing ${day_name}. A fresh week, sir. Shall we make it count?"
            ;;
        Friday)
            briefing="$briefing ${day_name}. The finish line is in sight, sir."
            ;;
    esac

    # System health
    local battery
    battery=$(pmset -g batt 2>/dev/null | grep -oE '[0-9]+%' | head -1 || echo "")
    if [[ -n "$battery" ]]; then
        local pct=${battery%\%}
        if (( pct < 20 )); then
            briefing="$briefing A word of caution, your battery is at ${battery}. I would advise connecting to power."
        fi
    fi

    # Uptime awareness
    local uptime_hours
    uptime_hours=$(python3 -c "
import subprocess, re
result = subprocess.run(['uptime'], capture_output=True, text=True)
output = result.stdout
# Try to extract hours from uptime
match = re.search(r'up\s+(\d+):(\d+)', output)
if match:
    print(match.group(1))
else:
    match = re.search(r'up\s+(\d+)\s+day', output)
    if match:
        print(int(match.group(1)) * 24)
    else:
        print('0')
" 2>/dev/null || echo "0")

    if (( uptime_hours > 72 )); then
        briefing="$briefing Your system has been running for over three days. A restart may improve performance, sir."
    fi

    briefing="$briefing I am at your disposal."

    speak "$briefing" "true"
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    load_settings

    case "${1:-}" in
        # ── Voice toggle ──
        on)
            set_voice_state "on"
            echo -e "${GREEN}●${NC} JARVIS voice ${GREEN}ON${NC}"
            load_env
            speak "Voice systems online, sir. I shall accompany all responses." "true"
            ;;
        off)
            echo -e "${RED}○${NC} JARVIS voice ${RED}OFF${NC}"
            load_env
            speak "Going silent, sir. I shall be here when you need me." "true"
            set_voice_state "off"
            ;;
        auto)
            set_voice_state "auto"
            echo -e "${YELLOW}◐${NC} JARVIS voice ${YELLOW}AUTO${NC}"
            load_env
            speak "Auto mode engaged, sir. I will speak only when it matters." "true"
            ;;
        status)
            show_status
            ;;
        greet)
            load_env
            greet
            ;;
        boot)
            "$ASSISTANT_DIR/bin/jarvis-boot" "${2:-}"
            ;;
        wake)
            # Pass through to jarvis-wake (e.g. "jarvis wake start", "jarvis wake stop")
            shift
            local subcmd="${1:-status}"
            "$ASSISTANT_DIR/bin/jarvis-wake" "--$subcmd"
            ;;

        # ── Config ──
        --help|-h)
            show_help
            ;;
        --settings)
            load_env
            show_settings
            ;;
        --set)
            load_env
            if [[ -z "${2:-}" || -z "${3:-}" ]]; then
                echo -e "${RED}Usage: jarvis --set <key> <value>${NC}"
                exit 1
            fi
            set_setting "$2" "$3"
            echo -e "${GREEN}Updated.${NC}"
            speak "Setting adjusted, sir. $(echo "$2" | sed 's/_/ /g') is now at $3." "true"
            ;;
        --voices)
            load_env
            list_voices
            ;;
        --voice)
            load_env
            if [[ -z "${2:-}" ]]; then
                echo -e "${RED}Usage: jarvis --voice <voice_id>${NC}"
                exit 1
            fi
            set_setting "voice_id" "$2"
            echo -e "${GREEN}Voice updated.${NC}"
            speak "Voice reconfigured, sir. How does this suit you?" "true"
            ;;
        --test)
            load_env
            test_voice
            ;;
        --stream)
            load_env
            if [[ -n "${2:-}" ]]; then
                speak_streaming "$2"
            fi
            ;;
        --speak)
            # Force-speak (ignores voice on/off state) — used by boot, --test, etc.
            load_env
            if [[ -n "${2:-}" ]]; then
                speak "$2" "true"
            fi
            ;;

        # ── Default: speak or pipe ──
        "")
            if [[ ! -t 0 ]]; then
                load_env
                local piped_text
                piped_text=$(cat)
                speak "$piped_text"
            else
                show_help
            fi
            ;;
        *)
            load_env
            speak "$1"
            ;;
    esac
}

main "$@"
