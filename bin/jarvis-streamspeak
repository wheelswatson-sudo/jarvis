#!/usr/bin/env python3
"""jarvis-streamspeak — read text deltas from stdin, speak sentences as they complete.

Designed for the streaming claude-CLI path (jarvis-hotkey, etc.):

    claude -p --output-format stream-json "..." \
      | jq -rj 'select(.event.type=="content_block_delta" and .event.delta.type=="text_delta") | .event.delta.text' \
      | jarvis-streamspeak

Each `jarvis --speak <sentence>` invocation blocks until its mp3 stream finishes
playing, so audio serializes naturally — no overlap. Full text is echoed to
stderr so the caller's log captures the response. Same sentence-boundary +
comma-fallback rules as the _TTSFeeder in jarvis-think.py.
"""
from __future__ import annotations

import os
import re
import subprocess
import sys
from pathlib import Path

JARVIS_BIN = Path(os.environ.get(
    "JARVIS_BIN",
    str(Path.home() / "jarvis" / "bin" / "jarvis"),
))
# Fallback: ~/.jarvis/bin/jarvis (the deployed copy)
if not JARVIS_BIN.exists():
    alt = Path.home() / ".jarvis" / "bin" / "jarvis"
    if alt.exists():
        JARVIS_BIN = alt

SENT_END = re.compile(r"[.!?](?=\s|$)")


def main() -> int:
    if not JARVIS_BIN.exists():
        sys.stderr.write(
            f"jarvis-streamspeak: {JARVIS_BIN} not found — falling back to passthrough\n"
        )
        for chunk in iter(lambda: sys.stdin.read(256), ""):
            sys.stderr.write(chunk)
            sys.stderr.flush()
        return 0

    # Bash feeder: read line, force-speak, repeat. --speak ignores voice on/off
    # so streaming works regardless of `jarvis off`.
    cmd = (
        'while IFS= read -r line; do '
        '  [ -n "$line" ] && "$0" --speak "$line" >/dev/null 2>&1; '
        'done'
    )
    feeder = subprocess.Popen(
        ["bash", "-c", cmd, str(JARVIS_BIN)],
        stdin=subprocess.PIPE,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        text=True,
    )

    buf = ""

    def send(sentence: str) -> None:
        if not feeder.stdin:
            return
        try:
            feeder.stdin.write(sentence + "\n")
            feeder.stdin.flush()
        except (BrokenPipeError, ValueError, OSError):
            pass

    def flush(force: bool = False) -> None:
        nonlocal buf
        while True:
            m = SENT_END.search(buf)
            if not m:
                if force and buf.strip():
                    send(buf.strip())
                    buf = ""
                elif not force and len(buf) > 140:
                    cm = re.search(r",\s", buf[80:])
                    if cm:
                        idx = 80 + cm.end()
                        send(buf[:idx].rstrip())
                        buf = buf[idx:]
                        continue
                break
            end = m.end()
            while end < len(buf) and buf[end].isspace():
                end += 1
            sentence = buf[:end].strip()
            buf = buf[end:]
            if sentence:
                send(sentence)

    try:
        # Small reads keep latency low — jq emits text deltas in bursts of a
        # few tokens (~5-30 chars) every 30-100ms.
        while True:
            chunk = sys.stdin.read(64)
            if not chunk:
                break
            buf += chunk
            sys.stderr.write(chunk)
            sys.stderr.flush()
            flush(force=False)
    except (BrokenPipeError, KeyboardInterrupt):
        pass

    flush(force=True)

    if feeder.stdin:
        try:
            feeder.stdin.close()
        except Exception:
            pass
    try:
        feeder.wait(timeout=120)
    except subprocess.TimeoutExpired:
        feeder.kill()

    sys.stderr.write("\n")
    return 0


if __name__ == "__main__":
    try:
        sys.exit(main())
    except KeyboardInterrupt:
        sys.exit(130)
