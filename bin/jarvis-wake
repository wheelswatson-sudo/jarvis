#!/usr/bin/env bash
# JARVIS — Always-On Wake Word Listener
# Listens 24/7 for "Hey Jarvis" then triggers conversation mode
#
# Usage:
#   jarvis-wake              Run wake word listener (foreground)
#   jarvis-wake --start      Install + start as background service (LaunchAgent)
#   jarvis-wake --stop       Stop background service
#   jarvis-wake --status     Check if running
#   jarvis-wake --logs       Tail the listener logs

set -euo pipefail

ASSISTANT_DIR="${ASSISTANT_DIR:-$HOME/.jarvis}"
VENV_PYTHON="$ASSISTANT_DIR/venv/bin/python3"
LISTENER_PY="$ASSISTANT_DIR/bin/wake-listener.py"
LAUNCHAGENT_PLIST="$HOME/Library/LaunchAgents/ai.jarvis.wake.plist"
LOG_FILE="$ASSISTANT_DIR/logs/wake.log"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

mkdir -p "$ASSISTANT_DIR/logs"

# ─── Status check ──────────────────────────────────────────────────────
check_running() {
    local output
    output=$(launchctl list 2>/dev/null || true)
    if echo "$output" | grep -q "ai.jarvis.wake"; then
        return 0
    fi
    return 1
}

# ─── Start as background service ──────────────────────────────────────
start_service() {
    if [[ ! -f "$VENV_PYTHON" ]]; then
        echo -e "${RED}Python venv not found.${NC}"
        echo -e "Run: ${CYAN}jarvis-wake --install${NC}"
        exit 1
    fi

    # Create LaunchAgent plist
    cat > "$LAUNCHAGENT_PLIST" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.jarvis.wake</string>
    <key>ProgramArguments</key>
    <array>
        <string>${VENV_PYTHON}</string>
        <string>${LISTENER_PY}</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>ASSISTANT_DIR</key>
        <string>${ASSISTANT_DIR}</string>
        <key>PATH</key>
        <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>${LOG_FILE}</string>
    <key>StandardErrorPath</key>
    <string>${LOG_FILE}</string>
</dict>
</plist>
EOF

    launchctl unload "$LAUNCHAGENT_PLIST" 2>/dev/null || true
    launchctl load "$LAUNCHAGENT_PLIST"

    # Give launchd a moment + a couple retries
    local i
    for i in 1 2 3 4 5; do
        sleep 1
        if check_running; then
            break
        fi
    done

    if check_running; then
        echo -e "${GREEN}● JARVIS wake word listener started${NC}"
        echo -e "${DIM}Say \"Hey Jarvis\" to activate${NC}"
        echo -e "${DIM}Logs: $LOG_FILE${NC}"
    else
        echo -e "${RED}Failed to start${NC}"
        echo -e "Check logs: ${CYAN}jarvis-wake --logs${NC}"
        exit 1
    fi
}

stop_service() {
    if [[ -f "$LAUNCHAGENT_PLIST" ]]; then
        launchctl unload "$LAUNCHAGENT_PLIST" 2>/dev/null || true
        rm -f "$LAUNCHAGENT_PLIST"
        echo -e "${YELLOW}○ JARVIS wake word listener stopped${NC}"
    else
        echo -e "${DIM}Listener was not running.${NC}"
    fi
}

show_status() {
    if check_running; then
        echo -e "${GREEN}● JARVIS wake word: LISTENING${NC}"
        echo -e "${DIM}Say \"Hey Jarvis\" to activate${NC}"
    else
        echo -e "${RED}○ JARVIS wake word: STOPPED${NC}"
        echo -e "${DIM}Start with: jarvis-wake --start${NC}"
    fi
}

show_logs() {
    if [[ -f "$LOG_FILE" ]]; then
        tail -50 -f "$LOG_FILE"
    else
        echo -e "${YELLOW}No logs yet.${NC}"
    fi
}

install_deps() {
    echo -e "${CYAN}Installing dependencies for wake word detection...${NC}"
    echo -e "${DIM}This takes 1-2 minutes.${NC}"
    echo ""

    # Check brew dependencies
    for pkg in portaudio python3; do
        if ! brew list "$pkg" &>/dev/null && ! command -v "$pkg" &>/dev/null; then
            echo -e "Installing $pkg..."
            brew install "$pkg" || true
        fi
    done

    # Create venv
    if [[ ! -d "$ASSISTANT_DIR/venv" ]]; then
        python3 -m venv "$ASSISTANT_DIR/venv"
    fi

    # Install Python packages
    "$ASSISTANT_DIR/venv/bin/pip" install --quiet --upgrade pip
    "$ASSISTANT_DIR/venv/bin/pip" install --quiet openwakeword sounddevice numpy

    echo -e "${GREEN}✓ Dependencies installed${NC}"
    echo -e "${DIM}Now run: jarvis-wake --start${NC}"
}

# ─── Main ──────────────────────────────────────────────────────────────
case "${1:-}" in
    --install)
        install_deps
        ;;
    --start)
        start_service
        ;;
    --stop)
        stop_service
        ;;
    --status)
        show_status
        ;;
    --logs)
        show_logs
        ;;
    --restart)
        stop_service
        sleep 1
        start_service
        ;;
    --help|-h|"")
        cat << EOF

    JARVIS — Wake Word Listener

    Always-on background service that listens for "Hey Jarvis"
    and triggers a voice conversation when detected.

    Usage:
      jarvis-wake --install    Install Python dependencies (one-time)
      jarvis-wake --start      Start the wake listener as a background service
      jarvis-wake --stop       Stop the listener
      jarvis-wake --status     Check if running
      jarvis-wake --logs       Tail the listener logs
      jarvis-wake --restart    Restart the listener

    First-time setup:
      1. jarvis-wake --install
      2. jarvis-wake --start
      3. Say "Hey Jarvis"

EOF
        ;;
    *)
        # Run listener in foreground (debugging)
        if [[ ! -f "$VENV_PYTHON" ]]; then
            echo -e "${RED}Run jarvis-wake --install first${NC}"
            exit 1
        fi
        exec "$VENV_PYTHON" "$LISTENER_PY"
        ;;
esac
