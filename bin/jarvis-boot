#!/usr/bin/env bash
# JARVIS — First boot cinematic experience
# Runs once on first launch, then never again (unless --reset)
set -euo pipefail

ASSISTANT_DIR="${ASSISTANT_DIR:-$HOME/.jarvis}"
ENV_FILE="$ASSISTANT_DIR/config/.env"
CONFIG_FILE="$ASSISTANT_DIR/config/settings.json"
BOOT_FLAG="$ASSISTANT_DIR/.booted"
JARVIS_BIN="$ASSISTANT_DIR/bin/jarvis"

CYAN='\033[0;36m'
GREEN='\033[0;32m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# Skip if already booted (unless --reset)
if [[ -f "$BOOT_FLAG" && "${1:-}" != "--reset" ]]; then
    exit 0
fi

[[ -f "$ENV_FILE" ]] && source "$ENV_FILE"

# ─── Identity (name-agnostic; works for any white-labeled assistant) ──
ASSISTANT_NAME="$(python3 -c "
import json
try:
    with open('$CONFIG_FILE') as f: cfg = json.load(f)
    print(cfg.get('assistant_name', 'JARVIS'))
except Exception:
    print('JARVIS')
" 2>/dev/null || echo "JARVIS")"

USER_NAME="$(python3 -c "
import json
try:
    with open('$CONFIG_FILE') as f: cfg = json.load(f)
    print(cfg.get('user_name') or '')
except Exception:
    pass
" 2>/dev/null || echo "")"
if [[ -z "$USER_NAME" ]]; then
    USER_NAME="$(git config --global user.name 2>/dev/null | awk '{print $1}' || true)"
    USER_NAME="${USER_NAME:-$(whoami)}"
fi

# ─── Banner — centered name in a frame, no hardcoded letters ─────────
print_banner() {
    local name_upper
    name_upper=$(echo "$ASSISTANT_NAME" | tr '[:lower:]' '[:upper:]')
    # Spaced letters for a cinematic feel: J A R V I S
    local spaced=""
    local i ch
    for (( i=0; i<${#name_upper}; i++ )); do
        ch="${name_upper:$i:1}"
        spaced+="${ch} "
    done
    spaced="${spaced% }"

    local total=58
    local content_len=${#spaced}
    local pad=$(( (total - content_len) / 2 ))
    local left right
    left=$(printf '%*s' "$pad" '')
    right=$(printf '%*s' "$(( total - content_len - pad ))" '')

    echo -e "${CYAN}"
    echo "    ╔══════════════════════════════════════════════════════════╗"
    echo "    ║${left}${spaced}${right}║"
    echo "    ╚══════════════════════════════════════════════════════════╝"
    echo -e "${NC}"
}

# ─── Boot animation ───────────────────────────────────────────────────
clear
echo ""
echo -e "${DIM}"
sleep 0.3
echo "    [INIT] Loading core systems..."
sleep 0.4
echo "    [INIT] Voice synthesis............ OK"
sleep 0.3
echo "    [INIT] Personality matrix......... OK"
sleep 0.3
echo "    [INIT] Context engine............. OK"
sleep 0.3
echo "    [INIT] Memory subsystem........... OK"
sleep 0.2
echo -e "${NC}"

print_banner
echo -e "    ${BOLD}${ASSISTANT_NAME}${NC}"
echo -e "    ${DIM}Powered by Claude + ElevenLabs${NC}"
echo ""
sleep 0.5

echo -e "    ${CYAN}Systems${NC}"
for label in "Voice       " "Intelligence" "Personality "; do
    echo -ne "    $label "
    for i in $(seq 1 20); do echo -ne "${GREEN}█${NC}"; sleep 0.02; done
    echo -e " ${GREEN}ONLINE${NC}"
done
echo ""

# ─── Greeting (spoken) — delegates to jarvis CLI for TTS ──────────────
hour=$(date +%H)
if (( hour < 12 )); then
    greeting="Good morning"
elif (( hour < 17 )); then
    greeting="Good afternoon"
else
    greeting="Good evening"
fi

if [[ ! -f "$BOOT_FLAG" ]]; then
    msg="${greeting}, sir. I am ${ASSISTANT_NAME}. Your personal artificial intelligence system. I have been configured to assist you with whatever you require. My voice, my personality, and my judgment are all at your disposal. I look forward to working with you, ${USER_NAME}. Shall we begin?"
else
    msg="${greeting}, sir. Systems recalibrated. All modules are online and operational. Ready when you are."
fi

if [[ -x "$JARVIS_BIN" ]]; then
    "$JARVIS_BIN" --speak "$msg" 2>/dev/null || true
fi

if [[ ! -f "$BOOT_FLAG" ]]; then
    echo -e "    ${GREEN}${BOLD}${ASSISTANT_NAME} is online.${NC}"
    echo ""
    cmd=$(basename "$JARVIS_BIN")
    echo -e "    ${DIM}Voice control:${NC}"
    echo -e "    ${CYAN}${cmd} on${NC}    — speak every response"
    echo -e "    ${CYAN}${cmd} off${NC}   — silent mode"
    echo -e "    ${CYAN}${cmd} auto${NC}  — speak when it matters"
    echo ""
else
    echo -e "    ${GREEN}${BOLD}${ASSISTANT_NAME} recalibrated.${NC}"
    echo ""
fi

date -u +"%Y-%m-%dT%H:%M:%SZ" > "$BOOT_FLAG"
