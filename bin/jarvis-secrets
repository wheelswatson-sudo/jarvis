#!/usr/bin/env bash
# JARVIS — Read API keys from the macOS Keychain, with .env fallback.
#
# Usage:
#   eval "$(jarvis-secrets --export)"   # source ANTHROPIC/ELEVENLABS/OPENAI keys
#   jarvis-secrets --get KEY            # print one key (Keychain → .env)
#   jarvis-secrets --set KEY            # prompt and store the value in Keychain
#   jarvis-secrets --migrate            # move every known key from .env into Keychain
#   jarvis-secrets --list               # report which keys are stored where
#
# Lookup precedence: macOS Keychain (service "jarvis") → ~/.jarvis/config/.env.
# Storing in Keychain keeps secrets out of plaintext config files; the .env path
# remains as a fallback so existing installs keep working without migration.
#
# On non-macOS systems (no `security` command), the helper degrades to .env-only.

set -euo pipefail

ASSISTANT_DIR="${ASSISTANT_DIR:-$HOME/.jarvis}"
ENV_FILE="$ASSISTANT_DIR/config/.env"
KEYCHAIN_SERVICE="jarvis"

KNOWN_KEYS=(ANTHROPIC_API_KEY ELEVENLABS_API_KEY OPENAI_API_KEY DEEPGRAM_API_KEY)

have_keychain() {
    command -v security >/dev/null 2>&1
}

read_keychain() {
    have_keychain || return 1
    security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$1" -w 2>/dev/null
}

read_env() {
    [[ -f "$ENV_FILE" ]] || return 1
    # Strip optional surrounding quotes; take the first match.
    awk -F= -v k="$1" '
        $1 == k {
            sub(/^[^=]*=/, "")
            gsub(/^"|"$/, "")
            gsub(/^\x27|\x27$/, "")
            print
            exit
        }
    ' "$ENV_FILE"
}

read_key() {
    local key="$1" val
    val=$(read_keychain "$key" || true)
    if [[ -n "$val" ]]; then
        printf '%s' "$val"
        return
    fi
    read_env "$key" || true
}

write_keychain() {
    have_keychain || {
        echo "jarvis-secrets: macOS \`security\` not available — cannot write Keychain" >&2
        return 1
    }
    security add-generic-password -U -s "$KEYCHAIN_SERVICE" -a "$1" -w "$2"
}

cmd_export() {
    local key val
    for key in "${KNOWN_KEYS[@]}"; do
        val=$(read_key "$key")
        [[ -n "$val" ]] && printf 'export %s=%q\n' "$key" "$val"
    done
}

cmd_get() {
    local key="${1:-}"
    [[ -z "$key" ]] && { echo "usage: jarvis-secrets --get KEY" >&2; return 1; }
    read_key "$key"
}

cmd_set() {
    local key="${1:-}"
    [[ -z "$key" ]] && { echo "usage: jarvis-secrets --set KEY" >&2; return 1; }
    have_keychain || {
        echo "jarvis-secrets: macOS \`security\` not available — cannot store in Keychain" >&2
        return 1
    }
    local val
    read -rsp "Value for $key: " val </dev/tty
    echo
    [[ -z "$val" ]] && { echo "jarvis-secrets: empty value, nothing stored" >&2; return 1; }
    write_keychain "$key" "$val"
    echo "Stored in Keychain (service=$KEYCHAIN_SERVICE, account=$key)."
}

cmd_migrate() {
    have_keychain || {
        echo "jarvis-secrets: macOS \`security\` not available — cannot migrate" >&2
        return 1
    }
    [[ -f "$ENV_FILE" ]] || { echo "jarvis-secrets: no .env at $ENV_FILE — nothing to migrate"; return 0; }
    local key val moved=0
    for key in "${KNOWN_KEYS[@]}"; do
        val=$(read_env "$key")
        [[ -z "$val" ]] && continue
        write_keychain "$key" "$val" && {
            echo "Migrated $key → Keychain."
            moved=$((moved + 1))
        }
    done
    if (( moved > 0 )); then
        echo
        echo "Done. The .env file is left in place as a fallback."
        echo "When you're confident Keychain works, you may delete the migrated lines from $ENV_FILE."
    else
        echo "No known keys found in $ENV_FILE."
    fi
}

cmd_list() {
    local key in_kc in_env
    printf '%-22s %-9s %-9s\n' "KEY" "KEYCHAIN" "ENV"
    for key in "${KNOWN_KEYS[@]}"; do
        in_kc="no"
        in_env="no"
        if have_keychain && security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$key" >/dev/null 2>&1; then
            in_kc="yes"
        fi
        [[ -n "$(read_env "$key")" ]] && in_env="yes"
        printf '%-22s %-9s %-9s\n' "$key" "$in_kc" "$in_env"
    done
}

case "${1:-}" in
    --export)  cmd_export ;;
    --get)     cmd_get "${2:-}" ;;
    --set)     cmd_set "${2:-}" ;;
    --migrate) cmd_migrate ;;
    --list)    cmd_list ;;
    -h|--help|"")
        sed -n '2,16p' "$0"
        ;;
    *)
        echo "jarvis-secrets: unknown command '$1'" >&2
        echo "usage: jarvis-secrets {--export|--get KEY|--set KEY|--migrate|--list}" >&2
        exit 2
        ;;
esac
