#!/usr/bin/env bash
# JARVIS — Voice Input (Speech-to-Text)
# Records from microphone, transcribes with whisper.cpp (offline) or OpenAI Whisper API
#
# Usage:
#   jarvis-listen                    Record until Enter, return transcript
#   jarvis-listen --auto             Record until 2s silence, return transcript
#   jarvis-listen --continuous       Continuous listening mode (loop)

set -euo pipefail

ASSISTANT_DIR="${ASSISTANT_DIR:-$HOME/.jarvis}"
ENV_FILE="$ASSISTANT_DIR/config/.env"
CACHE_DIR="$ASSISTANT_DIR/cache"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Config ────────────────────────────────────────────────────────────
WHISPER_MODEL=""
SAMPLE_RATE=16000
CHANNELS=1
BIT_DEPTH=16

# Find whisper binary (brew installs as whisper-cli, not whisper-cpp)
WHISPER_CMD=""
find_whisper_cmd() {
    if command -v whisper-cpp &>/dev/null; then
        WHISPER_CMD="whisper-cpp"
        return 0
    elif command -v whisper-cli &>/dev/null; then
        WHISPER_CMD="whisper-cli"
        return 0
    else
        local prefix
        prefix="$(brew --prefix whisper-cpp 2>/dev/null || echo "")"
        if [[ -x "$prefix/bin/whisper-cli" ]]; then
            WHISPER_CMD="$prefix/bin/whisper-cli"
            return 0
        fi
    fi
    return 1
}

# Find whisper model
find_whisper_model() {
    local prefix
    prefix="$(brew --prefix whisper-cpp 2>/dev/null || echo "")"

    # Check common locations
    for model_path in \
        "$ASSISTANT_DIR/models/ggml-base.en.bin" \
        "$prefix/models/ggml-base.en.bin" \
        "$HOME/.local/share/whisper-cpp/models/ggml-base.en.bin" \
        "/usr/local/share/whisper-cpp/models/ggml-base.en.bin"; do
        if [[ -f "$model_path" ]]; then
            WHISPER_MODEL="$model_path"
            return 0
        fi
    done
    return 1
}

# ─── Dependency check ──────────────────────────────────────────────────
check_deps() {
    local missing=false

    if ! command -v rec &>/dev/null && ! command -v sox &>/dev/null; then
        echo -e "${RED}Missing: sox (audio recording)${NC}"
        echo -e "  Install: ${CYAN}brew install sox${NC}"
        missing=true
    fi

    if ! command -v whisper-cpp &>/dev/null && ! command -v whisper-cli &>/dev/null && [[ ! -x "$(brew --prefix whisper-cpp 2>/dev/null)/bin/whisper-cli" ]]; then
        # Check for OpenAI API key as fallback
        if [[ -f "$ENV_FILE" ]]; then
            source "$ENV_FILE"
        fi
        if [[ -z "${OPENAI_API_KEY:-}" ]]; then
            echo -e "${YELLOW}whisper-cpp not found. Using OpenAI Whisper API requires OPENAI_API_KEY.${NC}"
            echo -e "  For offline: ${CYAN}brew install whisper-cpp${NC}"
            echo -e "  For cloud:   Add OPENAI_API_KEY to ${CYAN}$ENV_FILE${NC}"

            if [[ "$missing" == "true" ]]; then
                exit 1
            fi
        fi
    fi

    if [[ "$missing" == "true" ]]; then
        exit 1
    fi
}

# ─── Recording ─────────────────────────────────────────────────────────
record_until_enter() {
    local audio_file="$1"
    echo ""
    echo -e "    ${CYAN}●${NC} ${BOLD}JARVIS is listening...${NC}"
    echo -e "    ${DIM}Press Enter when finished speaking.${NC}"
    echo ""

    # Record in background
    rec -q -r "$SAMPLE_RATE" -c "$CHANNELS" -b "$BIT_DEPTH" "$audio_file" 2>/dev/null &
    local rec_pid=$!

    # Wait for Enter
    read -r -s

    # Stop recording
    kill "$rec_pid" 2>/dev/null
    wait "$rec_pid" 2>/dev/null || true

    echo -e "    ${DIM}Recording stopped.${NC}"
}

record_until_silence() {
    local audio_file="$1"
    local max_seconds="${LISTEN_MAX_SECONDS:-30}"
    echo ""
    echo -e "    ${CYAN}●${NC} ${BOLD}JARVIS is listening...${NC}"
    echo -e "    ${DIM}I will stop when you pause speaking (max ${max_seconds}s).${NC}"
    echo ""

    # Record until 2 seconds of silence — but cap total duration so we don't hang forever
    rec -q -r "$SAMPLE_RATE" -c "$CHANNELS" -b "$BIT_DEPTH" "$audio_file" \
        silence 1 0.1 1% 1 2.0 1% 2>/dev/null &
    local rec_pid=$!

    # Watchdog: kill rec if it runs too long
    ( sleep "$max_seconds" && kill "$rec_pid" 2>/dev/null ) &
    local watchdog_pid=$!

    wait "$rec_pid" 2>/dev/null || true
    kill "$watchdog_pid" 2>/dev/null || true
    wait "$watchdog_pid" 2>/dev/null || true

    echo -e "    ${DIM}Recording stopped.${NC}"
}

# ─── Transcription ─────────────────────────────────────────────────────
transcribe_whisper_cpp() {
    local audio_file="$1"

    if ! find_whisper_model; then
        echo -e "${RED}Whisper model not found.${NC}" >&2
        echo -e "Download: ${CYAN}jarvis-listen --download-model${NC}" >&2
        return 1
    fi

    # Transcribe
    find_whisper_cmd
    local result
    result=$($WHISPER_CMD -m "$WHISPER_MODEL" -f "$audio_file" -np -nt 2>/dev/null)

    # Clean up whisper output (remove leading/trailing whitespace and brackets)
    result=$(echo "$result" | sed 's/^\[.*\]//g' | xargs)

    echo "$result"
}

transcribe_openai() {
    local audio_file="$1"

    if [[ -z "${OPENAI_API_KEY:-}" ]]; then
        echo -e "${RED}OPENAI_API_KEY not set.${NC}" >&2
        return 1
    fi

    local result
    result=$(curl -s "https://api.openai.com/v1/audio/transcriptions" \
        -H "Authorization: Bearer ${OPENAI_API_KEY}" \
        -F "file=@${audio_file}" \
        -F "model=whisper-1" \
        -F "response_format=text" 2>/dev/null)

    echo "$result"
}

transcribe() {
    local audio_file="$1"

    # Check file has content
    local file_size
    file_size=$(wc -c < "$audio_file" | xargs)
    if (( file_size < 1000 )); then
        echo ""
        return 0
    fi

    # Prefer whisper.cpp (offline), fallback to OpenAI API
    if find_whisper_cmd && find_whisper_model; then
        transcribe_whisper_cpp "$audio_file"
    elif [[ -n "${OPENAI_API_KEY:-}" ]]; then
        transcribe_openai "$audio_file"
    else
        echo -e "${RED}No transcription engine available.${NC}" >&2
        return 1
    fi
}

# ─── Download whisper model ───────────────────────────────────────────
download_model() {
    local model_dir="$ASSISTANT_DIR/models"
    mkdir -p "$model_dir"

    echo -e "${CYAN}Downloading whisper base.en model (~150MB)...${NC}"

    local model_url="https://huggingface.co/ggerganov/whisper.cpp/resolve/main/ggml-base.en.bin"
    curl -L --progress-bar "$model_url" -o "$model_dir/ggml-base.en.bin"

    if [[ -f "$model_dir/ggml-base.en.bin" ]]; then
        echo -e "${GREEN}Model downloaded to $model_dir/ggml-base.en.bin${NC}"
    else
        echo -e "${RED}Download failed.${NC}"
        exit 1
    fi
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    # Load env if exists
    [[ -f "$ENV_FILE" ]] && source "$ENV_FILE"

    case "${1:-}" in
        --download-model)
            download_model
            exit 0
            ;;
        --help|-h)
            cat << 'EOF'

    JARVIS — Voice Input

    Usage:
      jarvis-listen                  Record until Enter, transcribe
      jarvis-listen --auto           Record until silence, transcribe
      jarvis-listen --continuous     Continuous listen-respond loop
      jarvis-listen --download-model Download whisper model (~150MB)

    Requirements:
      brew install sox whisper-cpp
      jarvis-listen --download-model

    Or set OPENAI_API_KEY in ~/.jarvis/config/.env for cloud transcription.

EOF
            exit 0
            ;;
    esac

    check_deps
    mkdir -p "$CACHE_DIR"

    local audio_file
    audio_file=$(mktemp "$CACHE_DIR/listen-XXXX.wav")

    case "${1:-}" in
        --auto)
            record_until_silence "$audio_file"
            ;;
        --continuous)
            echo -e "\n    ${CYAN}╔══════════════════════════════════════╗${NC}"
            echo -e "    ${CYAN}║${NC}   ${BOLD}JARVIS Continuous Listening Mode${NC}   ${CYAN}║${NC}"
            echo -e "    ${CYAN}╚══════════════════════════════════════╝${NC}"
            echo -e "    ${DIM}Ctrl+C to exit${NC}\n"

            while true; do
                audio_file=$(mktemp "$CACHE_DIR/listen-XXXX.wav")
                record_until_silence "$audio_file"

                echo -ne "    ${DIM}Transcribing...${NC} "
                local text
                text=$(transcribe "$audio_file")
                rm -f "$audio_file"

                if [[ -n "$text" ]]; then
                    echo -e "${GREEN}$text${NC}"
                    echo ""
                    echo "$text"  # Output for piping
                else
                    echo -e "${YELLOW}(no speech detected)${NC}"
                fi
                echo ""
            done
            exit 0
            ;;
        *)
            record_until_enter "$audio_file"
            ;;
    esac

    echo -ne "    ${DIM}Transcribing...${NC} "
    local text
    text=$(transcribe "$audio_file")
    rm -f "$audio_file"

    if [[ -n "$text" ]]; then
        echo -e "${GREEN}$text${NC}"
        echo ""
        # Output clean text to stdout for piping
        echo "$text"
    else
        echo -e "${YELLOW}(no speech detected)${NC}"
    fi
}

main "$@"
