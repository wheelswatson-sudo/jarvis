#!/usr/bin/env bash
# JARVIS — Full Voice Conversation Mode
# Speak → Transcribe → Claude → Speak response
# The complete Iron Man experience.
#
# Usage:
#   jarvis-converse                  One-shot: speak, get response
#   jarvis-converse --loop           Continuous conversation mode

set -euo pipefail

ASSISTANT_DIR="${ASSISTANT_DIR:-$HOME/.jarvis}"
ENV_FILE="$ASSISTANT_DIR/config/.env"
PERSONALITY="$ASSISTANT_DIR/config/personality.md"
JARVIS_BIN="$ASSISTANT_DIR/bin/jarvis"
LISTEN_BIN="$ASSISTANT_DIR/bin/jarvis-listen"
CONFIG_FILE="$ASSISTANT_DIR/config/settings.json"
HISTORY_FILE="$ASSISTANT_DIR/cache/conversation.json"
FILLER_BIN="$ASSISTANT_DIR/bin/jarvis-filler"
STREAM_BIN="$ASSISTANT_DIR/bin/jarvis-listen-stream"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Load env ──────────────────────────────────────────────────────────
# Keychain takes precedence over .env when both exist; .env stays as fallback.
[[ -f "$ENV_FILE" ]] && source "$ENV_FILE"
[[ -x "$ASSISTANT_DIR/bin/jarvis-secrets" ]] && eval "$("$ASSISTANT_DIR/bin/jarvis-secrets" --export 2>/dev/null)"

# ─── Speak with Enter-to-interrupt barge-in ───────────────────────────
# Background the speak; poll stdin for any keypress. If the user hits a key
# we kill the speak script's afplay child (and the script itself). On macOS
# bash 3.2 read -t fractional timeouts aren't supported, so we poll once a
# second — interruption latency is up to ~1s, which is fine for skipping.
speak_with_bargein() {
    local text="$1"
    [[ -z "$text" ]] && return 0

    "$JARVIS_BIN" "$text" 2>/dev/null &
    local speak_pid=$!

    while kill -0 "$speak_pid" 2>/dev/null; do
        if read -t 1 -s -n 1 _ </dev/tty 2>/dev/null; then
            # Kill the audio first so it stops immediately, then the parent script
            pkill -P "$speak_pid" 2>/dev/null || true
            kill "$speak_pid" 2>/dev/null || true
            echo -e "    ${DIM}(interrupted, sir)${NC}"
            break
        fi
    done
    wait "$speak_pid" 2>/dev/null || true
}

# ─── Think (delegates to jarvis-think.py for tool use + memory) ──────
# History persistence and the API loop both live in jarvis-think.py now.
# We keep this shell entry point thin so all the conversation logic is in
# one place (Python) regardless of whether you reach it via voice loop,
# --text, or the wake-listener.
#
# Voice modes pass stream=1 so jarvis-think.py streams sentence-by-sentence
# audio via its TTSFeeder while Claude is still generating. The caller MUST
# skip its trailing TTS call when stream=1 — otherwise the response is spoken
# twice. --text mode passes stream=0 (legacy: think returns full text, then
# the shell speaks it once at the end).
THINK_BIN="$ASSISTANT_DIR/bin/jarvis-think.py"

# ─── Listen (whisper default, optional Deepgram streaming) ────────────
# Selects the STT backend per JARVIS_STT. Deepgram runs jarvis-listen-stream
# --once which prints just the transcript on success or exits non-zero on
# any failure — empty stdout falls through to whisper. Whisper stays the
# universal fallback so the voice loop never breaks.
listen_for_transcript() {
    if [[ "${JARVIS_STT:-whisper}" == "deepgram" ]] && [[ -x "$STREAM_BIN" ]]; then
        local transcript
        transcript=$(JARVIS_STT=deepgram "$STREAM_BIN" --once 2>/dev/null || true)
        transcript="${transcript//$'\n'/}"
        if [[ -n "$transcript" ]]; then
            echo "$transcript"
            return 0
        fi
        echo -e "    ${DIM}Deepgram unavailable, falling back to whisper.${NC}" >&2
    fi
    "$LISTEN_BIN" 2>/dev/null | tail -1
}

# ─── Filler bridge ────────────────────────────────────────────────────
# Spawn jarvis-filler in the background while think() runs, so the user hears
# a brief "Hmm..." instead of dead air. The filler script self-delays 200ms;
# if think() returns before that, kill_filler aborts before any audio plays.
# The filler never enters conversation history — it's purely a UX signal.
start_filler() {
    [[ "${JARVIS_FILLER_BRIDGE:-1}" == "1" ]] || { echo ""; return 0; }
    [[ -x "$FILLER_BIN" ]] || { echo ""; return 0; }
    "$FILLER_BIN" </dev/null >/dev/null 2>&1 &
    echo "$!"
}

kill_filler() {
    local pid="${1:-}"
    [[ -n "$pid" ]] || return 0
    # Kill the say child first so audio cuts immediately, then the wrapper.
    pkill -P "$pid" 2>/dev/null || true
    kill "$pid" 2>/dev/null || true
    wait "$pid" 2>/dev/null || true
}

think() {
    local user_text="$1"
    local stream="${2:-0}"

    if [[ "$stream" != "1" ]]; then
        echo -ne "    ${DIM}JARVIS is thinking...${NC}"
    fi

    # Filler is only useful when we're going to be silent during think().
    # In stream=1 mode, jarvis-think.py is already piping sentences to TTS via
    # its _TTSFeeder, so a "Hmm..." would talk over the real response.
    local filler_pid=""
    if [[ "$stream" != "1" ]]; then
        filler_pid=$(start_filler)
    fi

    local response
    response=$(
        HISTORY_FILE="$HISTORY_FILE" \
        CONFIG_FILE="$CONFIG_FILE" \
        ASSISTANT_DIR="$ASSISTANT_DIR" \
        ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}" \
        JARVIS_VOICE_STREAM="$stream" \
        python3 "$THINK_BIN" "$user_text" 2>/dev/null
    )

    kill_filler "$filler_pid"

    if [[ "$stream" != "1" ]]; then
        echo -e "\r                              "  # Clear "thinking..."
    fi

    if [[ -n "$response" ]]; then
        echo "$response"
    else
        echo "I appear to be having a moment, sir. Could you repeat that?"
    fi
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    case "${1:-}" in
        --help|-h)
            cat << 'EOF'

    JARVIS — Voice Conversation

    Usage:
      jarvis-converse                One-shot: speak, get spoken response
      jarvis-converse --loop         Continuous conversation
      jarvis-converse --reset        Clear conversation history
      jarvis-converse --text "msg"   Text input (skip microphone)

    Requirements:
      - sox + whisper-cpp (for voice input)
      - ElevenLabs API key (for voice output)
      - Anthropic API key or anthropic Python SDK (for thinking)

EOF
            exit 0
            ;;
        --reset)
            rm -f "$HISTORY_FILE"
            echo -e "${GREEN}Conversation history cleared.${NC}"
            exit 0
            ;;
        --text)
            local text_input="${2:-}"
            if [[ -z "$text_input" ]]; then
                echo -e "${RED}Usage: jarvis-converse --text \"your message\"${NC}"
                exit 1
            fi
            echo -e "\n    ${GREEN}You:${NC} $text_input"
            local response
            response=$(think "$text_input")
            echo -e "    ${CYAN}JARVIS:${NC} $response"
            "$JARVIS_BIN" "$response" 2>/dev/null
            exit 0
            ;;
    esac

    if [[ "${1:-}" == "--loop" ]]; then
        echo ""
        echo -e "    ${CYAN}╔══════════════════════════════════════╗${NC}"
        echo -e "    ${CYAN}║${NC}   ${BOLD}JARVIS Conversation Mode${NC}           ${CYAN}║${NC}"
        echo -e "    ${CYAN}╚══════════════════════════════════════╝${NC}"
        echo -e "    ${DIM}Press Enter while JARVIS speaks to interrupt. Say \"goodbye\" to exit.${NC}"
        echo ""

        speak_with_bargein "Conversation mode active, sir. I am listening."

        while true; do
            local transcript
            transcript=$(listen_for_transcript)

            if [[ -z "$transcript" ]]; then
                continue
            fi

            echo -e "    ${GREEN}You:${NC} $transcript"

            if echo "$transcript" | grep -iqE "^(goodbye|exit|quit|stop|that will be all)"; then
                speak_with_bargein "Very good, sir. Will that be all?"
                echo -e "\n    ${DIM}Session ended.${NC}\n"
                exit 0
            fi

            # Voice loop: stream sentence-by-sentence audio from think.py.
            # think.py owns TTS (via its TTSFeeder) — we just print the final
            # text for the transcript and DO NOT speak it again ourselves.
            local response
            response=$(think "$transcript" 1)

            echo -e "    ${CYAN}JARVIS:${NC} $response"
            echo ""
        done
    else
        # One-shot mode (mic in, voice out — also streams).
        local transcript
        transcript=$(listen_for_transcript)

        if [[ -z "$transcript" ]]; then
            echo -e "    ${YELLOW}No speech detected, sir.${NC}"
            exit 0
        fi

        echo -e "    ${GREEN}You:${NC} $transcript"

        local response
        response=$(think "$transcript" 1)

        echo -e "    ${CYAN}JARVIS:${NC} $response"
    fi
}

main "$@"
