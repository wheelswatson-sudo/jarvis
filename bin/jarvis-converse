#!/usr/bin/env bash
# JARVIS — Full Voice Conversation Mode
# Speak → Transcribe → Claude → Speak response
# The complete Iron Man experience.
#
# Usage:
#   jarvis-converse                  One-shot: speak, get response
#   jarvis-converse --loop           Continuous conversation mode

set -euo pipefail

ASSISTANT_DIR="${ASSISTANT_DIR:-$HOME/.jarvis}"
ENV_FILE="$ASSISTANT_DIR/config/.env"
PERSONALITY="$ASSISTANT_DIR/config/personality.md"
JARVIS_BIN="$ASSISTANT_DIR/bin/jarvis"
LISTEN_BIN="$ASSISTANT_DIR/bin/jarvis-listen"
HISTORY_FILE="$ASSISTANT_DIR/cache/conversation.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Load env ──────────────────────────────────────────────────────────
[[ -f "$ENV_FILE" ]] && source "$ENV_FILE"

# ─── Conversation history ─────────────────────────────────────────────
init_history() {
    if [[ ! -f "$HISTORY_FILE" ]]; then
        local system_prompt
        system_prompt=$(cat "$PERSONALITY" 2>/dev/null || echo "You are JARVIS, an intelligent British AI assistant. Address the user as 'sir'. Be concise, witty, and helpful.")

        # Pass system prompt via stdin so any quotes/backticks/triple-quotes are safe
        HISTORY_FILE="$HISTORY_FILE" python3 -c "
import json, os, sys
system = sys.stdin.read()
history = [{'role': 'system', 'content': system}]
with open(os.environ['HISTORY_FILE'], 'w') as f:
    json.dump(history, f, indent=2)
" <<< "$system_prompt"
    fi
}

add_message() {
    local role="$1"
    local content="$2"
    # Content goes via stdin — string interpolation is unsafe when content
    # may contain ''' or other Python source-level escape sequences.
    ROLE="$role" HISTORY_FILE="$HISTORY_FILE" python3 -c "
import json, os, sys
content = sys.stdin.read()
with open(os.environ['HISTORY_FILE'], 'r') as f:
    history = json.load(f)
history.append({'role': os.environ['ROLE'], 'content': content})
if len(history) > 21:
    history = [history[0]] + history[-20:]
with open(os.environ['HISTORY_FILE'], 'w') as f:
    json.dump(history, f, indent=2)
" <<< "$content"
}

# ─── Think (Claude API) ───────────────────────────────────────────────
think() {
    local user_text="$1"

    add_message "user" "$user_text"

    echo -ne "    ${DIM}JARVIS is thinking...${NC}"

    # Single Python invocation: reads history, POSTs to Claude (urllib — no SDK needed),
    # parses response. Avoids 3-4 subprocess starts and any JSON injection risk.
    local response
    response=$(HISTORY_FILE="$HISTORY_FILE" \
               CONFIG_FILE="$CONFIG_FILE" \
               ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}" \
               python3 -c '
import json, os, sys, urllib.request, urllib.error

api_key = os.environ.get("ANTHROPIC_API_KEY", "")
if not api_key:
    print("I cannot reach Claude — the ANTHROPIC_API_KEY is not set, sir.")
    sys.exit(0)

with open(os.environ["HISTORY_FILE"]) as f:
    history = json.load(f)

# Optional model override from settings.json
model = "claude-haiku-4-5-20251001"
try:
    with open(os.environ["CONFIG_FILE"]) as f:
        cfg = json.load(f)
    if cfg.get("claude_model"):
        model = cfg["claude_model"]
except Exception:
    pass

system_msg = history[0]["content"] if history and history[0]["role"] == "system" else ""
messages = [m for m in history if m["role"] != "system"]

payload = json.dumps({
    "model": model,
    "max_tokens": 1024,
    "system": system_msg,
    "messages": messages,
}).encode()

req = urllib.request.Request(
    "https://api.anthropic.com/v1/messages",
    data=payload,
    headers={
        "x-api-key": api_key,
        "anthropic-version": "2023-06-01",
        "content-type": "application/json",
    },
)
try:
    with urllib.request.urlopen(req, timeout=30) as r:
        data = json.loads(r.read())
    if data.get("content"):
        print(data["content"][0].get("text", ""))
except urllib.error.HTTPError as e:
    try:
        err = json.loads(e.read()).get("error", {}).get("message", str(e))
    except Exception:
        err = str(e)
    print(f"I apologize sir, but the API returned an error: {err}")
except Exception as e:
    print(f"I appear to be having a moment, sir — {e}")
' 2>/dev/null)

    echo -e "\r                              "  # Clear "thinking..."

    if [[ -n "$response" ]]; then
        add_message "assistant" "$response"
        echo "$response"
    else
        echo "I appear to be having a moment, sir. Could you repeat that?"
    fi
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    case "${1:-}" in
        --help|-h)
            cat << 'EOF'

    JARVIS — Voice Conversation

    Usage:
      jarvis-converse                One-shot: speak, get spoken response
      jarvis-converse --loop         Continuous conversation
      jarvis-converse --reset        Clear conversation history
      jarvis-converse --text "msg"   Text input (skip microphone)

    Requirements:
      - sox + whisper-cpp (for voice input)
      - ElevenLabs API key (for voice output)
      - Anthropic API key or anthropic Python SDK (for thinking)

EOF
            exit 0
            ;;
        --reset)
            rm -f "$HISTORY_FILE"
            echo -e "${GREEN}Conversation history cleared.${NC}"
            exit 0
            ;;
        --text)
            init_history
            local text_input="${2:-}"
            if [[ -z "$text_input" ]]; then
                echo -e "${RED}Usage: jarvis-converse --text \"your message\"${NC}"
                exit 1
            fi
            echo -e "\n    ${GREEN}You:${NC} $text_input"
            local response
            response=$(think "$text_input")
            echo -e "    ${CYAN}JARVIS:${NC} $response"
            "$JARVIS_BIN" "$response" 2>/dev/null
            exit 0
            ;;
    esac

    init_history

    if [[ "${1:-}" == "--loop" ]]; then
        echo ""
        echo -e "    ${CYAN}╔══════════════════════════════════════╗${NC}"
        echo -e "    ${CYAN}║${NC}   ${BOLD}JARVIS Conversation Mode${NC}           ${CYAN}║${NC}"
        echo -e "    ${CYAN}╚══════════════════════════════════════╝${NC}"
        echo -e "    ${DIM}Press Enter to speak. Say \"goodbye\" to exit.${NC}"
        echo ""

        "$JARVIS_BIN" "Conversation mode active, sir. I am listening." 2>/dev/null

        while true; do
            # Listen
            local transcript
            transcript=$("$LISTEN_BIN" 2>/dev/null | tail -1)

            if [[ -z "$transcript" ]]; then
                continue
            fi

            echo -e "    ${GREEN}You:${NC} $transcript"

            # Check for exit
            if echo "$transcript" | grep -iqE "^(goodbye|exit|quit|stop|that will be all)"; then
                "$JARVIS_BIN" "Very good, sir. Will that be all?" 2>/dev/null
                echo -e "\n    ${DIM}Session ended.${NC}\n"
                exit 0
            fi

            # Think
            local response
            response=$(think "$transcript")

            # Display + speak
            echo -e "    ${CYAN}JARVIS:${NC} $response"
            "$JARVIS_BIN" "$response" 2>/dev/null
            echo ""
        done
    else
        # One-shot mode
        local transcript
        transcript=$("$LISTEN_BIN" 2>/dev/null | tail -1)

        if [[ -z "$transcript" ]]; then
            echo -e "    ${YELLOW}No speech detected, sir.${NC}"
            exit 0
        fi

        echo -e "    ${GREEN}You:${NC} $transcript"

        local response
        response=$(think "$transcript")

        echo -e "    ${CYAN}JARVIS:${NC} $response"
        "$JARVIS_BIN" "$response" 2>/dev/null
    fi
}

main "$@"
