#!/usr/bin/env bash
# JARVIS — Full Voice Conversation Mode
# Speak → Transcribe → Claude → Speak response
# The complete Iron Man experience.
#
# Usage:
#   jarvis-converse                  One-shot: speak, get response
#   jarvis-converse --loop           Continuous conversation mode

set -euo pipefail

JARVIS_DIR="${JARVIS_DIR:-$HOME/.jarvis}"
ENV_FILE="$JARVIS_DIR/config/.env"
PERSONALITY="$JARVIS_DIR/config/personality.md"
JARVIS_BIN="$JARVIS_DIR/bin/jarvis"
LISTEN_BIN="$JARVIS_DIR/bin/jarvis-listen"
HISTORY_FILE="$JARVIS_DIR/cache/conversation.json"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── Load env ──────────────────────────────────────────────────────────
[[ -f "$ENV_FILE" ]] && source "$ENV_FILE"

# ─── Conversation history ─────────────────────────────────────────────
init_history() {
    if [[ ! -f "$HISTORY_FILE" ]]; then
        local system_prompt
        system_prompt=$(cat "$PERSONALITY" 2>/dev/null || echo "You are JARVIS, an intelligent British AI assistant. Address the user as 'sir'. Be concise, witty, and helpful.")

        python3 -c "
import json
system = '''$(echo "$system_prompt" | sed "s/'/\\\\'/g")'''
history = [{'role': 'system', 'content': system}]
with open('$HISTORY_FILE', 'w') as f:
    json.dump(history, f, indent=2)
"
    fi
}

add_message() {
    local role="$1"
    local content="$2"
    python3 -c "
import json
with open('$HISTORY_FILE', 'r') as f:
    history = json.load(f)
history.append({'role': '$role', 'content': '''$(echo "$content" | sed "s/'/\\\\'/g")'''})
# Keep last 20 messages + system prompt
if len(history) > 21:
    history = [history[0]] + history[-20:]
with open('$HISTORY_FILE', 'w') as f:
    json.dump(history, f, indent=2)
"
}

# ─── Think (Claude API) ───────────────────────────────────────────────
think() {
    local user_text="$1"

    add_message "user" "$user_text"

    echo -ne "    ${DIM}JARVIS is thinking...${NC}"

    local response
    response=$(python3 -c "
import json, os, sys

try:
    from anthropic import Anthropic
except ImportError:
    # Fallback: use curl
    sys.exit(42)

client = Anthropic()

with open('$HISTORY_FILE', 'r') as f:
    history = json.load(f)

system_msg = history[0]['content'] if history and history[0]['role'] == 'system' else ''
messages = [m for m in history if m['role'] != 'system']

response = client.messages.create(
    model='claude-sonnet-4-6',
    max_tokens=1024,
    system=system_msg,
    messages=messages
)

text = response.content[0].text
print(text)
" 2>/dev/null)

    local exit_code=$?

    # Fallback to curl if anthropic SDK not available
    if [[ $exit_code -eq 42 ]]; then
        local api_key="${ANTHROPIC_API_KEY:-}"
        if [[ -z "$api_key" ]]; then
            echo -e "\r    ${RED}ANTHROPIC_API_KEY not set. Add it to $ENV_FILE${NC}"
            return 1
        fi

        local messages_json
        messages_json=$(python3 -c "
import json
with open('$HISTORY_FILE', 'r') as f:
    history = json.load(f)
messages = [m for m in history if m['role'] != 'system']
print(json.dumps(messages))
")

        local system_text
        system_text=$(python3 -c "
import json
with open('$HISTORY_FILE', 'r') as f:
    history = json.load(f)
print(history[0]['content'] if history and history[0]['role'] == 'system' else '')
")

        local payload
        payload=$(python3 -c "
import json, sys
messages = json.loads(sys.stdin.read())
print(json.dumps({
    'model': 'claude-sonnet-4-6',
    'max_tokens': 1024,
    'system': '''$(echo "$system_text" | head -c 2000 | sed "s/'/\\\\'/g")''',
    'messages': messages
}))
" <<< "$messages_json")

        response=$(curl -s "https://api.anthropic.com/v1/messages" \
            -H "x-api-key: ${api_key}" \
            -H "anthropic-version: 2023-06-01" \
            -H "content-type: application/json" \
            -d "$payload" 2>/dev/null | python3 -c "
import json, sys
data = json.load(sys.stdin)
if 'content' in data and data['content']:
    print(data['content'][0].get('text', ''))
elif 'error' in data:
    print('I apologize sir, but I encountered an error: ' + data['error'].get('message', 'unknown'))
" 2>/dev/null)
    fi

    echo -e "\r                              "  # Clear "thinking..."

    if [[ -n "$response" ]]; then
        add_message "assistant" "$response"
        echo "$response"
    else
        echo "I appear to be having a moment, sir. Could you repeat that?"
    fi
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    case "${1:-}" in
        --help|-h)
            cat << 'EOF'

    JARVIS — Voice Conversation

    Usage:
      jarvis-converse                One-shot: speak, get spoken response
      jarvis-converse --loop         Continuous conversation
      jarvis-converse --reset        Clear conversation history
      jarvis-converse --text "msg"   Text input (skip microphone)

    Requirements:
      - sox + whisper-cpp (for voice input)
      - ElevenLabs API key (for voice output)
      - Anthropic API key or anthropic Python SDK (for thinking)

EOF
            exit 0
            ;;
        --reset)
            rm -f "$HISTORY_FILE"
            echo -e "${GREEN}Conversation history cleared.${NC}"
            exit 0
            ;;
        --text)
            init_history
            local text_input="${2:-}"
            if [[ -z "$text_input" ]]; then
                echo -e "${RED}Usage: jarvis-converse --text \"your message\"${NC}"
                exit 1
            fi
            echo -e "\n    ${GREEN}You:${NC} $text_input"
            local response
            response=$(think "$text_input")
            echo -e "    ${CYAN}JARVIS:${NC} $response"
            "$JARVIS_BIN" "$response" 2>/dev/null
            exit 0
            ;;
    esac

    init_history

    if [[ "${1:-}" == "--loop" ]]; then
        echo ""
        echo -e "    ${CYAN}╔══════════════════════════════════════╗${NC}"
        echo -e "    ${CYAN}║${NC}   ${BOLD}JARVIS Conversation Mode${NC}           ${CYAN}║${NC}"
        echo -e "    ${CYAN}╚══════════════════════════════════════╝${NC}"
        echo -e "    ${DIM}Press Enter to speak. Say \"goodbye\" to exit.${NC}"
        echo ""

        "$JARVIS_BIN" "Conversation mode active, sir. I am listening." 2>/dev/null

        while true; do
            # Listen
            local transcript
            transcript=$("$LISTEN_BIN" 2>/dev/null | tail -1)

            if [[ -z "$transcript" ]]; then
                continue
            fi

            echo -e "    ${GREEN}You:${NC} $transcript"

            # Check for exit
            if echo "$transcript" | grep -iqE "^(goodbye|exit|quit|stop|that will be all)"; then
                "$JARVIS_BIN" "Very good, sir. Will that be all?" 2>/dev/null
                echo -e "\n    ${DIM}Session ended.${NC}\n"
                exit 0
            fi

            # Think
            local response
            response=$(think "$transcript")

            # Display + speak
            echo -e "    ${CYAN}JARVIS:${NC} $response"
            "$JARVIS_BIN" "$response" 2>/dev/null
            echo ""
        done
    else
        # One-shot mode
        local transcript
        transcript=$("$LISTEN_BIN" 2>/dev/null | tail -1)

        if [[ -z "$transcript" ]]; then
            echo -e "    ${YELLOW}No speech detected, sir.${NC}"
            exit 0
        fi

        echo -e "    ${GREEN}You:${NC} $transcript"

        local response
        response=$(think "$transcript")

        echo -e "    ${CYAN}JARVIS:${NC} $response"
        "$JARVIS_BIN" "$response" 2>/dev/null
    fi
}

main "$@"
