#!/usr/bin/env bash
# jarvis-hotkey — voice loop triggered by Hammerspoon (alt+cmd+J).
#
# Pipeline: jarvis-listen → claude -p (with JARVIS personality) → jarvis (speak).
# Stateless: no conversation memory — for memory-aware mode use jarvis-converse.
#
# Hammerspoon binding (~/.hammerspoon/init.lua):
#   hs.execute("/Users/watsonwheeler/jarvis/bin/jarvis-hotkey > /tmp/jarvis-hotkey.log 2>&1 &", true)
#
# Spec (per master_todo 2026-04-25):
#   - Apple Silicon `/opt/homebrew` PATH fallback
#   - 60s timeout on `claude -p`
#   - JARVIS personality injected via `--append-system-prompt`
set -euo pipefail

# PATH portable to Intel + Apple Silicon
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

JARVIS_DIR="${JARVIS_DIR:-$HOME/.jarvis}"
PERSONALITY="$JARVIS_DIR/config/personality.md"
SPEAK="$JARVIS_DIR/bin/jarvis"
LISTEN="$HOME/jarvis/bin/jarvis-listen"
# Prefer dev bin (newer features land here first), fall back to deployed copy
STREAMSPEAK="$HOME/jarvis/bin/jarvis-streamspeak"
[[ -x "$STREAMSPEAK" ]] || STREAMSPEAK="$JARVIS_DIR/bin/jarvis-streamspeak"

# Load secrets (Keychain → .env fallback) so claude has ANTHROPIC_API_KEY if needed
if [[ -x "$HOME/jarvis/bin/jarvis-secrets" ]]; then
  eval "$("$HOME/jarvis/bin/jarvis-secrets" --export 2>/dev/null)" || true
fi

# 60s budget on the claude call — try gtimeout (coreutils), fall back to perl alarm
run_with_timeout() {
  local secs="$1"; shift
  if command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$secs" "$@"
  elif command -v timeout >/dev/null 2>&1; then
    timeout "$secs" "$@"
  else
    perl -e 'alarm shift; exec @ARGV' "$secs" "$@"
  fi
}

speak() {
  local text="$1"
  [[ -z "$text" ]] && return 0
  if [[ -x "$SPEAK" ]]; then
    "$SPEAK" "$text" >/dev/null 2>&1 || true
  else
    say "$text" 2>/dev/null || true
  fi
}

# 1. Listen — record + transcribe
if [[ ! -x "$LISTEN" ]]; then
  echo "jarvis-hotkey: $LISTEN not found or not executable" >&2
  speak "I cannot hear you, sir. The listener is missing."
  exit 1
fi

TRANSCRIPT=$("$LISTEN" --auto 2>/dev/null | tail -1 || true)

if [[ -z "$TRANSCRIPT" ]]; then
  echo "jarvis-hotkey: empty transcript, exiting silently"
  exit 0
fi

echo "jarvis-hotkey: heard: $TRANSCRIPT"

# 2. Think + Speak — streamed end-to-end so first audio plays while Claude is
#    still generating later text. Pipeline:
#      claude -p --output-format stream-json   (emits ndjson events)
#        ↓
#      jq -rj  → extracts text-delta strings, joined with no separator
#        ↓
#      jarvis-streamspeak  → buffers into sentences, pipes each to `jarvis --speak`
#                             (which blocks per-sentence so audio serializes)
#
# We run claude with stderr captured so we can detect auth failures and fall
# back to a friendly spoken error rather than silence. jq's text deltas get
# echoed to stderr by jarvis-streamspeak, so the response shows up in the
# Hammerspoon log alongside diagnostic output.
PERSONA=""
[[ -f "$PERSONALITY" ]] && PERSONA=$(cat "$PERSONALITY")

JQ_FILTER='select(.event.type=="content_block_delta" and .event.delta.type=="text_delta") | .event.delta.text'
ERR_FILE=$(mktemp -t jarvis-hotkey.XXXXXX)

if [[ ! -x "$STREAMSPEAK" ]]; then
  echo "jarvis-hotkey: $STREAMSPEAK not found — install jarvis-streamspeak first" >&2
  speak "I am missing my streaming voice, sir."
  rm -f "$ERR_FILE"
  exit 1
fi

set +e
if [[ -n "$PERSONA" ]]; then
  run_with_timeout 60 claude -p --output-format stream-json --include-partial-messages \
      "$TRANSCRIPT" --model haiku --append-system-prompt "$PERSONA" 2>"$ERR_FILE" \
    | jq -rj "$JQ_FILTER" 2>/dev/null \
    | "$STREAMSPEAK"
else
  run_with_timeout 60 claude -p --output-format stream-json --include-partial-messages \
      "$TRANSCRIPT" --model haiku 2>"$ERR_FILE" \
    | jq -rj "$JQ_FILTER" 2>/dev/null \
    | "$STREAMSPEAK"
fi
PIPE_RC=${PIPESTATUS[0]}
set -e

if grep -q "Not logged in" "$ERR_FILE" 2>/dev/null; then
  echo "jarvis-hotkey: claude auth failed — run 'claude setup-token' to refresh" >&2
  speak "My credentials have lapsed, sir. Please run setup-token."
  rm -f "$ERR_FILE"
  exit 1
fi

if [[ "$PIPE_RC" -ne 0 ]]; then
  echo "jarvis-hotkey: claude exited $PIPE_RC. stderr:" >&2
  cat "$ERR_FILE" >&2
  rm -f "$ERR_FILE"
  exit "$PIPE_RC"
fi

rm -f "$ERR_FILE"
