#!/usr/bin/env bash
# JARVIS — Voice-enabled AI assistant powered by Claude + ElevenLabs
# Usage:
#   jarvis "text to speak"            Speak text aloud
#   jarvis on                         Turn voice on (persistent)
#   jarvis off                        Turn voice off (persistent)
#   jarvis auto                       Auto mode — speaks only important responses
#   jarvis status                     Show current voice state
#   jarvis --settings                 Show current personality settings
#   jarvis --set humor 60             Adjust a setting
#   jarvis --voices                   List available voices
#   jarvis --voice <voice_id>         Change voice
#   jarvis --test                     Test voice with a sample line
#   jarvis --help                     Show help

set -euo pipefail

JARVIS_DIR="${JARVIS_DIR:-$HOME/.jarvis}"
CONFIG_FILE="$JARVIS_DIR/config/settings.json"
ENV_FILE="$JARVIS_DIR/config/.env"
STATE_FILE="$JARVIS_DIR/state.json"
CACHE_DIR="$JARVIS_DIR/cache"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# ─── State management (voice toggle) ──────────────────────────────────
init_state() {
    if [[ ! -f "$STATE_FILE" ]]; then
        mkdir -p "$(dirname "$STATE_FILE")"
        echo '{"voice": "on"}' > "$STATE_FILE"
    fi
}

get_voice_state() {
    init_state
    python3 -c "import json; print(json.load(open('$STATE_FILE')).get('voice', 'on'))"
}

set_voice_state() {
    init_state
    python3 -c "
import json
with open('$STATE_FILE', 'r') as f:
    state = json.load(f)
state['voice'] = '$1'
with open('$STATE_FILE', 'w') as f:
    json.dump(state, f, indent=2)
"
}

# ─── Load config ───────────────────────────────────────────────────────
load_env() {
    if [[ ! -f "$ENV_FILE" ]]; then
        echo -e "${RED}JARVIS is not configured.${NC} Run: jarvis-setup"
        exit 1
    fi
    source "$ENV_FILE"
}

load_settings() {
    if [[ ! -f "$CONFIG_FILE" ]]; then
        mkdir -p "$(dirname "$CONFIG_FILE")"
        cat > "$CONFIG_FILE" << 'DEFAULTS'
{
    "voice_id": "JBFqnCBsd6RMkjVDRZzb",
    "voice_name": "George",
    "model_id": "eleven_multilingual_v2",
    "stability": 0.5,
    "similarity_boost": 0.85,
    "style": 0.2,
    "humor": 75,
    "formality": 80,
    "proactivity": 70,
    "honesty": 90
}
DEFAULTS
    fi
}

get_setting() {
    python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['$1'])"
}

set_setting() {
    python3 -c "
import json
with open('$CONFIG_FILE', 'r') as f:
    cfg = json.load(f)
try:
    cfg['$1'] = int('$2')
except ValueError:
    try:
        cfg['$1'] = float('$2')
    except ValueError:
        cfg['$1'] = '$2'
with open('$CONFIG_FILE', 'w') as f:
    json.dump(cfg, f, indent=4)
print('Updated $1 to $2')
"
}

# ─── Text processing ──────────────────────────────────────────────────
strip_markdown() {
    python3 -c "
import sys, re
text = sys.stdin.read()
# Remove code blocks
text = re.sub(r'\`\`\`[\s\S]*?\`\`\`', '', text)
# Remove inline code
text = re.sub(r'\`[^\`]+\`', '', text)
# Remove headers
text = re.sub(r'^#{1,6}\s+', '', text, flags=re.MULTILINE)
# Remove bold/italic
text = re.sub(r'\*{1,3}([^*]+)\*{1,3}', r'\1', text)
text = re.sub(r'_{1,3}([^_]+)_{1,3}', r'\1', text)
# Remove links, keep text
text = re.sub(r'\[([^\]]+)\]\([^)]+\)', r'\1', text)
# Remove images
text = re.sub(r'!\[([^\]]*)\]\([^)]+\)', '', text)
# Remove tables
text = re.sub(r'\|.*\|', '', text)
text = re.sub(r'^[-:| ]+$', '', text, flags=re.MULTILINE)
# Remove bullet points
text = re.sub(r'^\s*[-*+]\s+', '', text, flags=re.MULTILINE)
# Remove numbered lists prefix
text = re.sub(r'^\s*\d+\.\s+', '', text, flags=re.MULTILINE)
# Remove blockquotes
text = re.sub(r'^>\s+', '', text, flags=re.MULTILINE)
# Remove horizontal rules
text = re.sub(r'^---+$', '', text, flags=re.MULTILINE)
# Collapse whitespace
text = re.sub(r'\n{3,}', '\n\n', text)
text = text.strip()
print(text)
"
}

clean_for_speech() {
    python3 -c "
import sys, re
text = sys.stdin.read()

# Spell out common acronyms
acronyms = {
    'API': 'A P I', 'APIs': 'A P Is', 'CLI': 'C L I',
    'URL': 'U R L', 'URLs': 'U R Ls', 'JSON': 'Jason',
    'HTML': 'H T M L', 'CSS': 'C S S', 'SQL': 'sequel',
    'HTTP': 'H T T P', 'HTTPS': 'H T T P S',
    'SSH': 'S S H', 'DNS': 'D N S', 'AWS': 'A W S',
    'GCP': 'G C P', 'MCP': 'M C P', 'SDK': 'S D K',
    'IDE': 'I D E', 'JWT': 'J W T', 'OAuth': 'oh-auth',
    'CRUD': 'crud', 'REST': 'rest', 'UI': 'U I',
    'UX': 'U X', 'AI': 'A I', 'ML': 'M L',
    'GPU': 'G P U', 'CPU': 'C P U', 'RAM': 'ram',
    'SSD': 'S S D', 'NPM': 'N P M', 'PR': 'P R',
    'PRs': 'P Rs', 'CI': 'C I', 'CD': 'C D',
    'TTS': 'T T S', 'STT': 'S T T', 'LLM': 'L L M',
    'GPT': 'G P T', 'TLS': 'T L S', 'TCP': 'T C P',
    'IP': 'I P', 'DB': 'D B', 'HVAC': 'H vac',
    'CRM': 'C R M', 'ETA': 'E T A', 'FAQ': 'F A Q',
    'ASAP': 'A S A P', 'CEO': 'C E O', 'CTO': 'C T O',
    'CFO': 'C F O', 'COO': 'C O O', 'VP': 'V P',
}
for acr, spoken in acronyms.items():
    text = re.sub(r'\b' + acr + r'\b', spoken, text)

# Remove file paths
text = re.sub(r'[~/][a-zA-Z0-9_./-]+', '', text)
# Remove URLs
text = re.sub(r'https?://\S+', '', text)
# Clean up punctuation clusters
text = re.sub(r'[(){}\[\]<>]', '', text)
# Remove backtick fragments
text = re.sub(r'\`+', '', text)
# Collapse whitespace
text = re.sub(r'  +', ' ', text)
text = re.sub(r'\n{3,}', '\n\n', text)
text = text.strip()
print(text)
"
}

# ─── TTS Cache ─────────────────────────────────────────────────────────
get_cache_key() {
    echo -n "$1" | md5sum 2>/dev/null | cut -d' ' -f1 || echo -n "$1" | md5 2>/dev/null
}

check_cache() {
    local key
    key=$(get_cache_key "$1")
    local cached="$CACHE_DIR/${key}.mp3"
    if [[ -f "$cached" ]]; then
        echo "$cached"
        return 0
    fi
    return 1
}

# ─── Speak function ────────────────────────────────────────────────────
speak() {
    local text="$1"
    local force="${2:-false}"

    # Check voice state (unless forced)
    if [[ "$force" != "true" ]]; then
        local state
        state=$(get_voice_state)
        if [[ "$state" == "off" ]]; then
            return 0
        fi
    fi

    local voice_id model_id stability similarity style
    voice_id=$(get_setting "voice_id")
    model_id=$(get_setting "model_id")
    stability=$(get_setting "stability")
    similarity=$(get_setting "similarity_boost")
    style=$(get_setting "style")

    # Process text for speech
    text=$(echo "$text" | strip_markdown | clean_for_speech)

    # Truncate if too long
    if [[ ${#text} -gt 5000 ]]; then
        text="${text:0:4990}... I shall spare you the remainder, sir."
    fi

    # Skip if empty
    if [[ -z "$text" ]]; then
        return 0
    fi

    mkdir -p "$CACHE_DIR"

    # Check cache first
    local cached_file
    if cached_file=$(check_cache "${voice_id}:${text}"); then
        afplay "$cached_file" 2>/dev/null || mpv --no-video "$cached_file" 2>/dev/null
        return 0
    fi

    local cache_key audio_file
    cache_key=$(get_cache_key "${voice_id}:${text}")
    audio_file="$CACHE_DIR/${cache_key}.mp3"

    echo -e "${CYAN}JARVIS${NC} ${DIM}is speaking...${NC}"

    # Build JSON payload safely with python
    local payload
    payload=$(python3 -c "
import json, sys
text = sys.stdin.read()
print(json.dumps({
    'text': text,
    'model_id': '${model_id}',
    'voice_settings': {
        'stability': ${stability},
        'similarity_boost': ${similarity},
        'style': ${style}
    }
}))
" <<< "$text")

    local http_code
    http_code=$(curl -s -w "%{http_code}" \
        "https://api.elevenlabs.io/v1/text-to-speech/${voice_id}" \
        -H "xi-api-key: ${ELEVENLABS_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "$payload" \
        --output "$audio_file")

    if [[ "$http_code" != "200" ]]; then
        echo -e "${RED}Voice synthesis failed (HTTP $http_code).${NC}"
        echo -e "${YELLOW}Falling back to system voice...${NC}"
        say "$text" 2>/dev/null || true
        rm -f "$audio_file"
        return 1
    fi

    # Play audio
    afplay "$audio_file" 2>/dev/null || mpv --no-video "$audio_file" 2>/dev/null || {
        echo -e "${RED}No audio player found.${NC}"
        return 1
    }

    # Cleanup — keep cache under 50MB
    local cache_size
    cache_size=$(du -sm "$CACHE_DIR" 2>/dev/null | cut -f1)
    if [[ "${cache_size:-0}" -gt 50 ]]; then
        ls -t "$CACHE_DIR"/*.mp3 2>/dev/null | tail -n +20 | xargs rm -f 2>/dev/null
    fi
}

# ─── Streaming speak (sentence by sentence) ───────────────────────────
speak_streaming() {
    local text="$1"
    local force="${2:-false}"

    # Check voice state
    if [[ "$force" != "true" ]]; then
        local state
        state=$(get_voice_state)
        if [[ "$state" == "off" ]]; then
            return 0
        fi
    fi

    # Split into sentences and speak each one
    echo "$text" | strip_markdown | clean_for_speech | python3 -c "
import sys, re
text = sys.stdin.read().strip()
# Split on sentence boundaries
sentences = re.split(r'(?<=[.!?])\s+', text)
# Group short sentences together (min ~40 chars per chunk for natural flow)
chunks = []
current = ''
for s in sentences:
    if len(current) + len(s) < 120:
        current = (current + ' ' + s).strip()
    else:
        if current:
            chunks.append(current)
        current = s
if current:
    chunks.append(current)
for chunk in chunks:
    print(chunk)
" | while IFS= read -r sentence; do
        if [[ -n "$sentence" ]]; then
            speak "$sentence" "$force"
        fi
    done
}

# ─── Commands ──────────────────────────────────────────────────────────
show_help() {
    cat << 'EOF'

    ╔══════════════════════════════════════════════════════╗
    ║              J.A.R.V.I.S. Voice System              ║
    ║       Just A Rather Very Intelligent System          ║
    ╚══════════════════════════════════════════════════════╝

    Voice Control:
      jarvis on                      Turn voice ON
      jarvis off                     Turn voice OFF
      jarvis auto                    Auto mode (smart filtering)
      jarvis status                  Show voice state

    Commands:
      jarvis greet                   Context-aware greeting + briefing
      jarvis boot                    Run boot-up sequence
      jarvis "text"                  Speak text aloud
      jarvis --stream "text"         Speak with streaming (sentence-by-sentence)
      echo "text" | jarvis           Pipe text to speak

    Configuration:
      jarvis --settings              Show personality settings
      jarvis --set <key> <value>     Adjust a setting
      jarvis --voices                List available ElevenLabs voices
      jarvis --voice <voice_id>      Switch voice
      jarvis --test                  Test voice

    Personality Settings:
      humor       (0-100)  Wit intensity. Default: 75
      formality   (0-100)  Protocol level. Default: 80
      proactivity (0-100)  Anticipation level. Default: 70
      honesty     (0-100)  Directness. Default: 90

    Setup:
      jarvis-setup                   First-time configuration

EOF
}

show_status() {
    local state
    state=$(get_voice_state)
    local icon color label
    case "$state" in
        on)   icon="●" ; color="$GREEN" ; label="ON — All responses spoken" ;;
        off)  icon="○" ; color="$RED"   ; label="OFF — Silent mode" ;;
        auto) icon="◐" ; color="$YELLOW"; label="AUTO — Smart filtering" ;;
    esac
    echo ""
    echo -e "    ${CYAN}JARVIS Voice:${NC} ${color}${icon} ${label}${NC}"
    echo ""
    echo -e "    ${DIM}Toggle:  jarvis on | jarvis off | jarvis auto${NC}"
    echo ""
}

show_settings() {
    echo ""
    echo -e "    ${CYAN}╔══════════════════════════════════════╗${NC}"
    echo -e "    ${CYAN}║${NC}       J.A.R.V.I.S. Settings         ${CYAN}║${NC}"
    echo -e "    ${CYAN}╚══════════════════════════════════════╝${NC}"
    echo ""

    local state
    state=$(get_voice_state)
    local state_icon state_color
    case "$state" in
        on)   state_icon="●" ; state_color="$GREEN" ;;
        off)  state_icon="○" ; state_color="$RED" ;;
        auto) state_icon="◐" ; state_color="$YELLOW" ;;
    esac
    echo -e "    Voice State      ${state_color}${state_icon} ${state}${NC}"
    echo ""

    python3 -c "
import json
with open('$CONFIG_FILE') as f:
    cfg = json.load(f)
labels = {
    'voice_name': 'Voice',
    'voice_id': 'Voice ID',
    'model_id': 'Model',
    'stability': 'Stability',
    'similarity_boost': 'Similarity',
    'style': 'Style',
    'humor': 'Humor',
    'formality': 'Formality',
    'proactivity': 'Proactivity',
    'honesty': 'Honesty'
}
for key, label in labels.items():
    val = cfg.get(key, 'N/A')
    bar = ''
    if isinstance(val, int) and 0 <= val <= 100:
        filled = val // 5
        bar = f' [{\"█\" * filled}{\"░\" * (20 - filled)}]'
    print(f'    {label:<16} {val}{bar}')
"
    echo ""
}

list_voices() {
    echo -e "\n    ${CYAN}Available Voices${NC}\n"
    curl -s "https://api.elevenlabs.io/v1/voices" \
        -H "xi-api-key: ${ELEVENLABS_API_KEY}" \
        | python3 -c "
import json, sys
data = json.load(sys.stdin)
for v in data.get('voices', []):
    labels = v.get('labels', {})
    accent = labels.get('accent', 'unknown')
    gender = labels.get('gender', '?')
    desc = labels.get('descriptive', '')
    name = v['name']
    vid = v['voice_id']
    print(f'    {name:<40} {gender:<8} {accent:<15} {vid}')
"
    echo ""
}

test_voice() {
    speak "Systems operational, sir. Voice synthesis is functioning within normal parameters. I trust the quality meets your expectations. If not, I have several alternatives prepared." "true"
}

# ─── Context-aware greeting ───────────────────────────────────────────
greet() {
    local hour greeting time_context day_name
    hour=$(date +%H)
    day_name=$(date +%A)

    if (( hour < 6 )); then
        greeting="Burning the midnight oil, sir?"
        time_context="late_night"
    elif (( hour < 12 )); then
        greeting="Good morning, sir."
        time_context="morning"
    elif (( hour < 17 )); then
        greeting="Good afternoon, sir."
        time_context="afternoon"
    elif (( hour < 21 )); then
        greeting="Good evening, sir."
        time_context="evening"
    else
        greeting="Working late, sir. I trust it is for good reason."
        time_context="night"
    fi

    # Build contextual briefing
    local briefing="$greeting"

    # Day awareness
    case "$day_name" in
        Saturday|Sunday)
            briefing="$briefing It is ${day_name}. I would suggest rest, but I suspect you have other plans."
            ;;
        Monday)
            briefing="$briefing ${day_name}. A fresh week, sir. Shall we make it count?"
            ;;
        Friday)
            briefing="$briefing ${day_name}. The finish line is in sight, sir."
            ;;
    esac

    # System health
    local battery
    battery=$(pmset -g batt 2>/dev/null | grep -oE '[0-9]+%' | head -1 || echo "")
    if [[ -n "$battery" ]]; then
        local pct=${battery%\%}
        if (( pct < 20 )); then
            briefing="$briefing A word of caution, your battery is at ${battery}. I would advise connecting to power."
        fi
    fi

    # Uptime awareness
    local uptime_hours
    uptime_hours=$(python3 -c "
import subprocess, re
result = subprocess.run(['uptime'], capture_output=True, text=True)
output = result.stdout
# Try to extract hours from uptime
match = re.search(r'up\s+(\d+):(\d+)', output)
if match:
    print(match.group(1))
else:
    match = re.search(r'up\s+(\d+)\s+day', output)
    if match:
        print(int(match.group(1)) * 24)
    else:
        print('0')
" 2>/dev/null || echo "0")

    if (( uptime_hours > 72 )); then
        briefing="$briefing Your system has been running for over three days. A restart may improve performance, sir."
    fi

    briefing="$briefing I am at your disposal."

    speak "$briefing" "true"
}

# ─── Main ──────────────────────────────────────────────────────────────
main() {
    load_settings

    case "${1:-}" in
        # ── Voice toggle ──
        on)
            set_voice_state "on"
            echo -e "${GREEN}●${NC} JARVIS voice ${GREEN}ON${NC}"
            load_env
            speak "Voice systems online, sir. I shall accompany all responses." "true"
            ;;
        off)
            echo -e "${RED}○${NC} JARVIS voice ${RED}OFF${NC}"
            load_env
            speak "Going silent, sir. I shall be here when you need me." "true"
            set_voice_state "off"
            ;;
        auto)
            set_voice_state "auto"
            echo -e "${YELLOW}◐${NC} JARVIS voice ${YELLOW}AUTO${NC}"
            load_env
            speak "Auto mode engaged, sir. I will speak only when it matters." "true"
            ;;
        status)
            show_status
            ;;
        greet)
            load_env
            greet
            ;;
        boot)
            "$JARVIS_DIR/bin/jarvis-boot" "${2:-}"
            ;;

        # ── Config ──
        --help|-h)
            show_help
            ;;
        --settings)
            load_env
            show_settings
            ;;
        --set)
            load_env
            if [[ -z "${2:-}" || -z "${3:-}" ]]; then
                echo -e "${RED}Usage: jarvis --set <key> <value>${NC}"
                exit 1
            fi
            set_setting "$2" "$3"
            echo -e "${GREEN}Updated.${NC}"
            speak "Setting adjusted, sir. $(echo "$2" | sed 's/_/ /g') is now at $3." "true"
            ;;
        --voices)
            load_env
            list_voices
            ;;
        --voice)
            load_env
            if [[ -z "${2:-}" ]]; then
                echo -e "${RED}Usage: jarvis --voice <voice_id>${NC}"
                exit 1
            fi
            set_setting "voice_id" "$2"
            echo -e "${GREEN}Voice updated.${NC}"
            speak "Voice reconfigured, sir. How does this suit you?" "true"
            ;;
        --test)
            load_env
            test_voice
            ;;
        --stream)
            load_env
            if [[ -n "${2:-}" ]]; then
                speak_streaming "$2"
            fi
            ;;

        # ── Default: speak or pipe ──
        "")
            if [[ ! -t 0 ]]; then
                load_env
                local piped_text
                piped_text=$(cat)
                speak "$piped_text"
            else
                show_help
            fi
            ;;
        *)
            load_env
            speak "$1"
            ;;
    esac
}

main "$@"
