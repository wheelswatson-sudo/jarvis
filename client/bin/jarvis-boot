#!/usr/bin/env bash
# JARVIS вҖ” First boot cinematic experience
# Runs once on first launch, then never again (unless reset)
set -euo pipefail

JARVIS_DIR="${JARVIS_DIR:-$HOME/.jarvis}"
ENV_FILE="$JARVIS_DIR/config/.env"
CONFIG_FILE="$JARVIS_DIR/config/settings.json"
BOOT_FLAG="$JARVIS_DIR/.booted"

# Colors
CYAN='\033[0;36m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
DIM='\033[2m'
BOLD='\033[1m'
NC='\033[0m'

# Check if already booted
if [[ -f "$BOOT_FLAG" && "${1:-}" != "--reset" ]]; then
    exit 0
fi

source "$ENV_FILE"

# в”Җв”Җв”Җ Speak helper (inline, no dependency on jarvis script) в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
boot_speak() {
    local text="$1"
    local voice_id model_id
    voice_id=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['voice_id'])")
    model_id=$(python3 -c "import json; print(json.load(open('$CONFIG_FILE'))['model_id'])")

    local audio_file="/tmp/jarvis_boot_$RANDOM.mp3"
    local payload
    payload=$(python3 -c "
import json
text = '''$text'''
print(json.dumps({
    'text': text,
    'model_id': '$model_id',
    'voice_settings': {'stability': 0.5, 'similarity_boost': 0.85, 'style': 0.2}
}))
")

    curl -s "https://api.elevenlabs.io/v1/text-to-speech/${voice_id}" \
        -H "xi-api-key: ${ELEVENLABS_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "$payload" \
        --output "$audio_file" 2>/dev/null

    afplay "$audio_file" 2>/dev/null || mpv --no-video "$audio_file" 2>/dev/null
    rm -f "$audio_file"
}

# в”Җв”Җв”Җ Time awareness в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
get_greeting() {
    local hour
    hour=$(date +%H)
    if (( hour < 12 )); then
        echo "Good morning"
    elif (( hour < 17 )); then
        echo "Good afternoon"
    else
        echo "Good evening"
    fi
}

# в”Җв”Җв”Җ Boot sequence в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
clear

# Phase 1: System initialization animation
echo ""
echo -e "${DIM}"
sleep 0.3
echo "    [INIT] Loading core systems..."
sleep 0.4
echo "    [INIT] Voice synthesis............ OK"
sleep 0.3
echo "    [INIT] Personality matrix......... OK"
sleep 0.3
echo "    [INIT] Context engine............. OK"
sleep 0.3
echo "    [INIT] Memory subsystem........... OK"
sleep 0.2
echo -e "${NC}"

# Phase 2: JARVIS logo reveal
echo -e "${CYAN}"
cat << 'BANNER'
       в–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•— в–Ҳв–Ҳв•—   в–Ҳв–Ҳв•—в–Ҳв–Ҳв•—в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
       в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв•җв•җв•қ
       в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•—
  в–Ҳв–Ҳ   в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•‘в–Ҳв–Ҳв•”в•җв•җв–Ҳв–Ҳв•—в•ҡв–Ҳв–Ҳв•— в–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘в•ҡв•җв•җв•җв•җв–Ҳв–Ҳв•‘
  в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қв–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘в–Ҳв–Ҳв•‘  в–Ҳв–Ҳв•‘ в•ҡв–Ҳв–Ҳв–Ҳв–Ҳв•”в•қ в–Ҳв–Ҳв•‘в–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв–Ҳв•‘
   в•ҡв•җв•җв•җв•җв•қ в•ҡв•җв•қ  в•ҡв•җв•қв•ҡв•җв•қ  в•ҡв•җв•қ  в•ҡв•җв•җв•җв•қ  в•ҡв•җв•қв•ҡв•җв•җв•җв•җв•җв•җв•қ
BANNER
echo -e "${NC}"
echo -e "    ${BOLD}Just A Rather Very Intelligent System${NC}"
echo -e "    ${DIM}v1.0 вҖ” Powered by Claude + ElevenLabs${NC}"
echo ""

sleep 0.5

# Phase 3: Status bars
echo -e "    ${CYAN}Systems${NC}"
echo -ne "    Voice        "
for i in $(seq 1 20); do echo -ne "${GREEN}в–Ҳ${NC}"; sleep 0.02; done
echo -e " ${GREEN}ONLINE${NC}"

echo -ne "    Intelligence "
for i in $(seq 1 20); do echo -ne "${GREEN}в–Ҳ${NC}"; sleep 0.02; done
echo -e " ${GREEN}ONLINE${NC}"

echo -ne "    Personality  "
for i in $(seq 1 20); do echo -ne "${GREEN}в–Ҳ${NC}"; sleep 0.02; done
echo -e " ${GREEN}ONLINE${NC}"

echo ""

# Phase 4: Greeting (spoken)
greeting=$(get_greeting)

# Get user's name from git config or system
user_name=$(git config --global user.name 2>/dev/null || whoami)
first_name=$(echo "$user_name" | awk '{print $1}')

# Check if this is the very first boot ever
if [[ ! -f "$BOOT_FLAG" ]]; then
    # First time ever вҖ” full introduction
    boot_speak "${greeting}, sir. I am JARVIS. Your personal artificial intelligence system. I have been configured to assist you with whatever you require. My voice, my personality, and my judgment are all at your disposal. I look forward to working with you, ${first_name}. Shall we begin?"

    echo -e "    ${GREEN}${BOLD}JARVIS is online.${NC}"
    echo ""
    echo -e "    ${DIM}Voice control:${NC}"
    echo -e "    ${CYAN}jarvis on${NC}    вҖ” I'll speak every response"
    echo -e "    ${CYAN}jarvis off${NC}   вҖ” Silent mode"
    echo -e "    ${CYAN}jarvis auto${NC}  вҖ” I speak when it matters"
    echo ""
    echo -e "    ${DIM}\"Will that be all, sir?\"${NC}"
    echo ""
else
    # Subsequent resets вҖ” shorter greeting
    boot_speak "${greeting}, sir. Systems recalibrated. All modules are online and operational. Ready when you are."

    echo -e "    ${GREEN}${BOLD}JARVIS recalibrated.${NC}"
    echo ""
fi

# Mark as booted
date -u +"%Y-%m-%dT%H:%M:%SZ" > "$BOOT_FLAG"
